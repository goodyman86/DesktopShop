@{
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var product = ViewBag.Product as DesktopShop.Domain.Entities.Product;
    var relatedProducts = ViewBag.RelatedProducts as List<DesktopShop.Domain.Entities.Product>;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Shop")">Cửa hàng</a></li>
        @if (product.Category != null)
        {
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Shop", new { categoryId = product.CategoryId })">@product.Category.Name</a>
            </li>
        }
        <li class="breadcrumb-item active">@product.Name</li>
    </ol>
</nav>

<div class="row g-4">
    <!-- Product Image -->
    <div class="col-md-5">
        <div class="bg-white rounded-3 shadow-sm p-3 text-center">
            @if (!string.IsNullOrEmpty(product.ImageUrl))
            {
                <img src="@product.ImageUrl" alt="@product.Name" class="img-fluid rounded" style="max-height:400px;object-fit:contain;" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center bg-light rounded" style="height:400px;">
                    <i class="fas fa-desktop fa-5x text-muted"></i>
                </div>
            }
        </div>
    </div>

    <!-- Product Info -->
    <div class="col-md-7">
        <div class="bg-white rounded-3 shadow-sm p-4">
            @if (product.Category != null)
            {
                <span class="badge bg-secondary mb-2">@product.Category.Name</span>
            }
            <h3 class="fw-bold mb-3">@product.Name</h3>

            <h4 class="text-danger fw-bold mb-4">@product.Price.ToString("#,0") ₫</h4>

            <!-- Specs -->
            <div class="mb-4">
                <h6 class="fw-semibold mb-3"><i class="fas fa-microchip me-2"></i>Thông số kỹ thuật</h6>
                <table class="table table-sm">
                    @if (!string.IsNullOrEmpty(product.CPU))
                    {
                        <tr><td class="fw-semibold" style="width:120px;">CPU</td><td>@product.CPU</td></tr>
                    }
                    @if (!string.IsNullOrEmpty(product.RAM))
                    {
                        <tr><td class="fw-semibold">RAM</td><td>@product.RAM</td></tr>
                    }
                    @if (!string.IsNullOrEmpty(product.GPU))
                    {
                        <tr><td class="fw-semibold">GPU</td><td>@product.GPU</td></tr>
                    }
                    @if (!string.IsNullOrEmpty(product.Storage))
                    {
                        <tr><td class="fw-semibold">Lưu trữ</td><td>@product.Storage</td></tr>
                    }
                </table>
            </div>

            <!-- Stock -->
            @if (product.StockQuantity > 0)
            {
                if (product.StockQuantity <= product.MinStockLevel)
                {
                    <p class="text-warning fw-semibold mb-3">
                        <i class="fas fa-exclamation-triangle me-1"></i>Sắp hết hàng — Chỉ còn @product.StockQuantity sản phẩm
                    </p>
                }
                else
                {
                    <p class="text-success mb-3">
                        <i class="fas fa-check-circle me-1"></i>Còn hàng (@product.StockQuantity sản phẩm)
                    </p>
                }
            }
            else
            {
                <p class="text-danger mb-3"><i class="fas fa-times-circle me-1"></i>Hết hàng</p>
            }

            <!-- Add to cart -->
            @if (product.StockQuantity > 0)
            {
                <form method="post" action="@Url.Action("Add", "Cart")" class="d-flex align-items-center gap-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@product.Id" />
                    <div class="input-group" style="width:130px;">
                        <button type="button" class="btn btn-outline-secondary" onclick="changeQty(-1)">−</button>
                        <input type="number" name="quantity" id="qtyInput" value="1" min="1" max="@product.StockQuantity" class="form-control text-center" />
                        <button type="button" class="btn btn-outline-secondary" onclick="changeQty(1)">+</button>
                    </div>
                    <button type="submit" class="btn btn-add-cart btn-lg px-4">
                        <i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ hàng
                    </button>
                </form>
            }
        </div>

        <!-- Description -->
        @if (!string.IsNullOrEmpty(product.Description))
        {
            <div class="bg-white rounded-3 shadow-sm p-4 mt-3">
                <h6 class="fw-semibold mb-2"><i class="fas fa-info-circle me-2"></i>Mô tả</h6>
                <p class="text-muted mb-0">@product.Description</p>
            </div>
        }
    </div>
</div>

<!-- Related Products -->
@if (relatedProducts != null && relatedProducts.Any())
{
    <div class="mt-5">
        <h5 class="fw-bold mb-3"><i class="fas fa-th-large me-2"></i>Sản phẩm liên quan</h5>
        <div class="row g-4">
            @foreach (var p in relatedProducts)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card product-card h-100 shadow-sm">
                        <a href="@Url.Action("Detail", "Shop", new { id = p.Id })">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" class="card-img-top" alt="@p.Name" />
                            }
                            else
                            {
                                <div class="card-img-top d-flex align-items-center justify-content-center bg-light">
                                    <i class="fas fa-desktop fa-3x text-muted"></i>
                                </div>
                            }
                        </a>
                        <div class="card-body d-flex flex-column">
                            <a href="@Url.Action("Detail", "Shop", new { id = p.Id })" class="text-decoration-none">
                                <h6 class="product-name mb-2">@p.Name</h6>
                            </a>
                            <p class="product-price mt-auto mb-0">@p.Price.ToString("#,0") ₫</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@section scripts {
    <script>
        function changeQty(delta) {
            var input = document.getElementById('qtyInput');
            var val = parseInt(input.value) + delta;
            var max = parseInt(input.getAttribute('max'));
            if (val < 1) val = 1;
            if (val > max) val = max;
            input.value = val;
        }
    </script>
}
