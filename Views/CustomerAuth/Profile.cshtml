@{
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var customer = ViewBag.Customer as DesktopShop.Domain.Entities.Customer;
}

<div class="row justify-content-center mt-3">
    <div class="col-lg-8">

        <!-- Header -->
        <div class="d-flex align-items-center mb-4">
            <div class="position-relative me-3">
                <div id="customerAvatarPreview" class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center"
                     style="width:80px;height:80px;font-size:2rem;overflow:hidden;cursor:pointer;" onclick="document.getElementById('customerAvatarInput').click();" title="Nhấn để thay đổi ảnh">
                    @if (!string.IsNullOrEmpty(customer.AvatarUrl))
                    {
                        <img src="@customer.AvatarUrl" style="width:100%;height:100%;object-fit:cover;" alt="Avatar" />
                    }
                    else
                    {
                        <i class="fas fa-user"></i>
                    }
                </div>
                <button type="button" class="btn btn-sm btn-dark rounded-circle position-absolute" style="bottom:0;right:0;width:28px;height:28px;padding:0;" onclick="document.getElementById('customerAvatarInput').click();" title="Thay đổi ảnh">
                    <i class="fas fa-camera" style="font-size:0.75rem;"></i>
                </button>
                <input type="file" id="customerAvatarInput" accept=".jpg,.jpeg,.png,.webp" style="display:none;" />
            </div>
            <div>
                <h4 class="fw-bold mb-0">@customer.FullName</h4>
                <small class="text-muted"><i class="fas fa-at me-1"></i>@customer.Username</small>
                <span class="text-muted mx-2">•</span>
                <small class="text-muted">Thành viên từ @customer.CreatedAt.ToString("dd/MM/yyyy")</small>
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs" id="profileTabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link active fw-semibold" id="info-tab" data-bs-toggle="tab" data-bs-target="#infoPane" type="button">
                    <i class="fas fa-id-card me-1"></i>Thông tin cá nhân
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link fw-semibold" id="password-tab" data-bs-toggle="tab" data-bs-target="#passwordPane" type="button">
                    <i class="fas fa-key me-1"></i>Đổi mật khẩu
                </button>
            </li>
        </ul>

        <div class="tab-content mt-0">

            <!-- Tab 1: Thông tin cá nhân -->
            <div class="tab-pane fade show active" id="infoPane">
                <div class="card border-0 shadow-sm rounded-top-0 rounded-bottom-3">
                    <div class="card-body p-4">

                        @if (ViewBag.Success != null)
                        {
                            <div class="alert alert-success py-2">
                                <i class="fas fa-check-circle me-1"></i>@ViewBag.Success
                            </div>
                        }
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger py-2">
                                <i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error
                            </div>
                        }

                        <form method="post" action="@Url.Action("UpdateProfile", "CustomerAuth")">
                            @Html.AntiForgeryToken()

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Tên đăng nhập</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                                        <input type="text" class="form-control bg-light" value="@customer.Username" disabled />
                                    </div>
                                    <small class="text-muted">Không thể thay đổi tên đăng nhập</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                                        <input type="text" name="fullName" class="form-control" value="@customer.FullName" required />
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                        <input type="email" name="email" class="form-control" value="@customer.Email" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Số điện thoại</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                        <input type="tel" name="phone" class="form-control" value="@customer.Phone" />
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">Địa chỉ</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
                                    <input type="text" name="address" class="form-control" value="@customer.Address" placeholder="Nhập địa chỉ giao hàng" />
                                </div>
                            </div>

                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-dark px-4">
                                    <i class="fas fa-save me-1"></i>Lưu thay đổi
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Tab 2: Đổi mật khẩu -->
            <div class="tab-pane fade" id="passwordPane">
                <div class="card border-0 shadow-sm rounded-top-0 rounded-bottom-3">
                    <div class="card-body p-4">

                        @if (ViewBag.PasswordSuccess != null)
                        {
                            <div class="alert alert-success py-2">
                                <i class="fas fa-check-circle me-1"></i>@ViewBag.PasswordSuccess
                            </div>
                        }
                        @if (ViewBag.PasswordError != null)
                        {
                            <div class="alert alert-danger py-2">
                                <i class="fas fa-exclamation-circle me-1"></i>@ViewBag.PasswordError
                            </div>
                        }

                        <form method="post" action="@Url.Action("ChangePassword", "CustomerAuth")">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                    <input type="password" name="currentPassword" class="form-control" required />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Mật khẩu mới <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-key"></i></span>
                                    <input type="password" name="newPassword" class="form-control" required minlength="6"
                                           placeholder="Ít nhất 6 ký tự" />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-key"></i></span>
                                    <input type="password" name="confirmNewPassword" class="form-control" required minlength="6"
                                           placeholder="Nhập lại mật khẩu mới" />
                                </div>
                            </div>

                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-dark px-4">
                                    <i class="fas fa-save me-1"></i>Đổi mật khẩu
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(function () {
            // Auto-switch to password tab if there's a password message
            @if (ViewBag.PasswordError != null || ViewBag.PasswordSuccess != null)
            {
                <text>
                var passwordTab = new bootstrap.Tab(document.getElementById('password-tab'));
                passwordTab.show();
                </text>
            }

            // Customer avatar upload handling
            $('#customerAvatarInput').on('change', function () {
                var file = this.files[0];
                if (!file) return;

                // Validate file size (2MB max)
                if (file.size > 2 * 1024 * 1024) {
                    Swal.fire('Lỗi', 'Kích thước file không được vượt quá 2MB.', 'error');
                    this.value = '';
                    return;
                }

                // Validate file type
                var allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
                if (!allowedTypes.includes(file.type)) {
                    Swal.fire('Lỗi', 'Chỉ chấp nhận file ảnh (.jpg, .jpeg, .png, .webp).', 'error');
                    this.value = '';
                    return;
                }

                // Preview image
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#customerAvatarPreview').html('<img src="' + e.target.result + '" style="width: 100%; height: 100%; object-fit: cover;" alt="Avatar" />');
                };
                reader.readAsDataURL(file);

                // Upload to server
                var formData = new FormData();
                formData.append('file', file);

                Swal.fire({
                    title: 'Đang tải lên...',
                    text: 'Vui lòng đợi',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '/api/users/upload-avatar',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false
                }).done(function (res) {
                    // Update avatar URL in database
                    $.ajax({
                        url: '@Url.Action("UpdateAvatar", "CustomerAuth")',
                        type: 'POST',
                        data: { avatarUrl: res.avatarUrl },
                        headers: {
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        }
                    }).done(function () {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: 'Đã cập nhật ảnh đại diện.',
                            timer: 1500,
                            showConfirmButton: false
                        });
                    }).fail(function () {
                        Swal.fire('Lỗi', 'Không thể cập nhật ảnh đại diện.', 'error');
                    });
                }).fail(function (xhr) {
                    var msg = 'Lỗi không xác định';
                    if (xhr.responseJSON) msg = xhr.responseJSON.message || xhr.responseJSON.Message || JSON.stringify(xhr.responseJSON);
                    Swal.fire('Lỗi', 'Upload ảnh thất bại: ' + msg, 'error');
                    // Restore previous avatar or icon
                    @if (!string.IsNullOrEmpty(customer.AvatarUrl))
                    {
                        <text>$('#customerAvatarPreview').html('<img src="@customer.AvatarUrl" style="width: 100%; height: 100%; object-fit: cover;" alt="Avatar" />');</text>
                    }
                    else
                    {
                        <text>$('#customerAvatarPreview').html('<i class="fas fa-user"></i>');</text>
                    }
                });
            });
        });
    </script>
}
