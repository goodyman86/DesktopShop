@{
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var orders = ViewBag.Orders as List<DesktopShop.Domain.Entities.Order>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="fas fa-box me-2"></i>Đơn hàng của tôi</h4>
    <a href="@Url.Action("Index", "Shop")" class="btn btn-outline-dark btn-sm">
        <i class="fas fa-store me-1"></i>Tiếp tục mua hàng
    </a>
</div>

@if (TempData["OrderSuccess"] != null)
{
    <div class="alert alert-success py-2"><i class="fas fa-check-circle me-1"></i>@TempData["OrderSuccess"]</div>
}
@if (TempData["OrderError"] != null)
{
    <div class="alert alert-danger py-2"><i class="fas fa-exclamation-circle me-1"></i>@TempData["OrderError"]</div>
}

@if (orders != null && orders.Any())
{
    <div class="row g-3">
        @foreach (var order in orders)
        {
            var statusClass = "";
            var statusText = "";
            var statusIcon = "";
            switch (order.Status)
            {
                case DesktopShop.Domain.Enums.OrderStatus.Pending:
                    statusClass = "bg-warning text-dark";
                    statusText = "Chờ xử lý";
                    statusIcon = "fas fa-clock";
                    break;
                case DesktopShop.Domain.Enums.OrderStatus.Confirmed:
                    statusClass = "bg-info text-white";
                    statusText = "Đã xác nhận";
                    statusIcon = "fas fa-check";
                    break;
                case DesktopShop.Domain.Enums.OrderStatus.Completed:
                    statusClass = "bg-success";
                    statusText = "Hoàn thành";
                    statusIcon = "fas fa-check-double";
                    break;
                case DesktopShop.Domain.Enums.OrderStatus.Cancelled:
                    statusClass = "bg-danger";
                    statusText = "Đã hủy";
                    statusIcon = "fas fa-times";
                    break;
            }

            var paymentIcon = "";
            var paymentText = "";
            switch (order.PaymentMethod)
            {
                case DesktopShop.Domain.Enums.PaymentMethod.CashOnDelivery:
                    paymentIcon = "fas fa-money-bill-wave";
                    paymentText = "COD";
                    break;
                case DesktopShop.Domain.Enums.PaymentMethod.BankTransfer:
                    paymentIcon = "fas fa-university";
                    paymentText = "Chuyển khoản";
                    break;
                case DesktopShop.Domain.Enums.PaymentMethod.CreditCard:
                    paymentIcon = "fas fa-credit-card";
                    paymentText = "Thẻ";
                    break;
                case DesktopShop.Domain.Enums.PaymentMethod.EWallet:
                    paymentIcon = "fas fa-wallet";
                    paymentText = "Ví điện tử";
                    break;
            }

            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-3">
                        <div class="row align-items-center">
                            <!-- Order info -->
                            <div class="col-md-3">
                                <span class="fw-bold text-dark" style="font-size:0.95rem;">@order.OrderCode</span>
                                <br />
                                <small class="text-muted">
                                    <i class="fas fa-calendar me-1"></i>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </small>
                            </div>

                            <!-- Items count -->
                            <div class="col-md-2 text-center">
                                <span class="text-muted small">Sản phẩm</span>
                                <br />
                                <span class="fw-semibold">@order.OrderDetails.Count món</span>
                            </div>

                            <!-- Total -->
                            <div class="col-md-2 text-center">
                                <span class="text-muted small">Tổng tiền</span>
                                <br />
                                <span class="fw-bold" style="color:#e94560;">@order.TotalAmount.ToString("#,0") ₫</span>
                            </div>

                            <!-- Payment Method -->
                            <div class="col-md-2 text-center">
                                <span class="text-muted small">Thanh toán</span>
                                <br />
                                <span class="fw-semibold" style="font-size:0.85rem;">
                                    <i class="@paymentIcon me-1 text-primary"></i>@paymentText
                                </span>
                            </div>

                            <!-- Status -->
                            <div class="col-md-2 text-center">
                                <span class="badge @statusClass px-3 py-2">
                                    <i class="@statusIcon me-1"></i>@statusText
                                </span>
                            </div>

                            <!-- Action -->
                            <div class="col-md-1 text-end">
                                <a href="@Url.Action("OrderDetail", "CustomerAuth", new { id = order.Id })"
                                   class="btn btn-outline-dark btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (order.Status == DesktopShop.Domain.Enums.OrderStatus.Pending)
                                {
                                    <form method="post" action="@Url.Action("CancelOrder", "CustomerAuth")" class="d-inline mt-1" onsubmit="return confirm('Bạn có chắc muốn hủy đơn hàng này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
        <h5 class="text-muted">Bạn chưa có đơn hàng nào</h5>
        <p class="text-muted">Hãy khám phá cửa hàng và đặt hàng ngay!</p>
        <a href="@Url.Action("Index", "Shop")" class="btn btn-dark mt-2">
            <i class="fas fa-store me-1"></i>Đến cửa hàng
        </a>
    </div>
}
