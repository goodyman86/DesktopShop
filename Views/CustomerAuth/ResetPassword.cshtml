@{
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="fas fa-lock fa-3x text-success mb-2"></i>
                    <h4 class="fw-bold">Đặt lại mật khẩu</h4>
                    <p class="text-muted small">Tạo mật khẩu mới cho tài khoản của bạn</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">
                        <i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error
                    </div>
                }

                <form method="post" action="@Url.Action("ResetPassword", "CustomerAuth")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="username" value="@ViewBag.Username" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tài khoản</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                            <input type="text" class="form-control" value="@ViewBag.Username" disabled />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input type="password" name="newPassword" class="form-control" placeholder="Nhập mật khẩu mới"
                                   minlength="6" required autofocus />
                        </div>
                        <small class="text-muted">Mật khẩu phải có ít nhất 6 ký tự</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Xác nhận mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input type="password" name="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới"
                                   minlength="6" required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 fw-semibold py-2">
                        <i class="fas fa-check me-1"></i>Đặt lại mật khẩu
                    </button>
                </form>

                <div class="text-center mt-3">
                    <p class="mb-0 small">
                        <a href="@Url.Action("Login", "CustomerAuth")" class="text-decoration-none" style="color:#e94560;">
                            <i class="fas fa-arrow-left me-1"></i>Quay lại đăng nhập
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
