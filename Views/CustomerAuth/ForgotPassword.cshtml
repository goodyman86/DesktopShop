@{
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="fas fa-key fa-3x text-muted mb-2"></i>
                    <h4 class="fw-bold">Quên mật khẩu</h4>
                    <p class="text-muted small">Nhập thông tin tài khoản để đặt lại mật khẩu</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">
                        <i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error
                    </div>
                }

                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-success py-2">
                        <i class="fas fa-check-circle me-1"></i>@ViewBag.Success
                    </div>
                }

                <form method="post" action="@Url.Action("ForgotPassword", "CustomerAuth")">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên đăng nhập</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                            <input type="text" name="username" class="form-control" placeholder="Nhập tên đăng nhập"
                                   value="@(ViewBag.Username ?? "")" required autofocus />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Email</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                            <input type="email" name="email" class="form-control" placeholder="Nhập email đã đăng ký"
                                   value="@(ViewBag.Email ?? "")" required />
                        </div>
                        <small class="text-muted">Nhập email đã đăng ký với tài khoản</small>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 fw-semibold py-2">
                        <i class="fas fa-paper-plane me-1"></i>Xác nhận
                    </button>
                </form>

                <div class="text-center mt-3">
                    <p class="mb-0 small">
                        <a href="@Url.Action("Login", "CustomerAuth")" class="text-decoration-none" style="color:#e94560;">
                            <i class="fas fa-arrow-left me-1"></i>Quay lại đăng nhập
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
