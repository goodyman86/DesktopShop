@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu - DesktopShop Admin</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- FontAwesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --primary: #1a73e8;
            --primary-dark: #1557b0;
            --primary-light: #e8f0fe;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-400: #9ca3af;
            --gray-600: #4b5563;
            --gray-800: #1f2937;
            --radius: 12px;
            --shadow-lg: 0 8px 30px rgba(0,0,0,.12);
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        .login-container {
            width: 100%;
            max-width: 420px;
        }

        .login-card {
            background: #fff;
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
            overflow: hidden;
        }

        .login-header {
            background: #16a34a;
            padding: 32px 32px 28px;
            text-align: center;
            color: #fff;
        }

        .login-header .brand-icon {
            width: 60px;
            height: 60px;
            background: rgba(255,255,255,.15);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin-bottom: 12px;
        }

        .login-header h1 {
            font-size: 1.4rem;
            font-weight: 700;
            margin: 0 0 4px;
        }

        .login-header p {
            font-size: .85rem;
            opacity: .85;
            margin: 0;
        }

        .login-body {
            padding: 32px;
        }

        .form-label {
            font-weight: 600;
            font-size: .85rem;
            color: var(--gray-600);
            margin-bottom: 6px;
        }

        .input-group-text {
            background: var(--gray-50);
            border-right: none;
            color: var(--gray-400);
        }

        .form-control {
            border-left: none;
            font-size: .9rem;
            padding: 10px 14px;
        }

        .form-control:focus {
            box-shadow: 0 0 0 3px rgba(22, 163, 74, .15);
            border-color: #16a34a;
        }

        .input-group .form-control:focus + .input-group-text,
        .input-group:focus-within .input-group-text {
            border-color: #16a34a;
        }

        .form-control:disabled {
            background: var(--gray-100);
        }

        .btn-login {
            background: #16a34a;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 12px;
            font-size: .95rem;
            font-weight: 600;
            width: 100%;
            cursor: pointer;
            transition: background .2s;
        }

        .btn-login:hover {
            background: #15803d;
            color: #fff;
        }

        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            border-radius: 8px;
            font-size: .85rem;
            padding: 10px 14px;
        }

        .login-footer {
            text-align: center;
            padding: 0 32px 24px;
            font-size: .78rem;
            color: var(--gray-400);
        }

        .back-link {
            display: inline-block;
            margin-top: 16px;
            color: var(--primary);
            text-decoration: none;
            font-size: .85rem;
            font-weight: 500;
        }

        .back-link:hover {
            text-decoration: underline;
        }

        .form-text {
            font-size: .78rem;
            color: var(--gray-400);
            margin-top: 4px;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="brand-icon">
                    <i class="fa-solid fa-lock"></i>
                </div>
                <h1>Đặt lại mật khẩu</h1>
                <p>Tạo mật khẩu mới cho tài khoản</p>
            </div>

            <div class="login-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger mb-3">
                        <i class="fa-solid fa-circle-exclamation me-1"></i>@ViewBag.Error
                    </div>
                }

                @using (Html.BeginForm("ResetPassword", "Auth", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="username" value="@ViewBag.Username" />

                    <div class="mb-3">
                        <label class="form-label">Tài khoản</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-user"></i></span>
                            <input type="text" class="form-control" value="@ViewBag.Username" disabled />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                            <input type="password" class="form-control" name="newPassword" id="newPassword"
                                   placeholder="Nhập mật khẩu mới" minlength="6" required autofocus />
                        </div>
                        <div class="form-text">Mật khẩu phải có ít nhất 6 ký tự</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                            <input type="password" class="form-control" name="confirmPassword" id="confirmPassword"
                                   placeholder="Nhập lại mật khẩu mới" minlength="6" required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-login">
                        <i class="fa-solid fa-check me-2"></i>Đặt lại mật khẩu
                    </button>

                    <div class="text-center">
                        <a href="@Url.Action("Login", "Auth")" class="back-link">
                            <i class="fa-solid fa-arrow-left me-1"></i>Quay lại đăng nhập
                        </a>
                    </div>
                }
            </div>

            <div class="login-footer">
                &copy; 2025 DesktopShop. Trang quản trị hệ thống.
            </div>
        </div>
    </div>

    <script>
        // Client-side password match validation
        document.querySelector('form').addEventListener('submit', function(e) {
            var newPass = document.getElementById('newPassword').value;
            var confirmPass = document.getElementById('confirmPassword').value;

            if (newPass !== confirmPass) {
                e.preventDefault();
                alert('Mật khẩu xác nhận không khớp!');
                return false;
            }
        });
    </script>
</body>
</html>
