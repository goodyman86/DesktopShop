@{
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var cartItems = ViewBag.CartItems as List<WebApplication1.Controllers.CartItem>;
    decimal total = ViewBag.Total;
}

<h4 class="fw-bold mb-4"><i class="fas fa-shopping-cart me-2"></i>Giỏ hàng của bạn</h4>

@if (TempData["CartError"] != null)
{
    <div class="alert alert-danger">@TempData["CartError"]</div>
}
@if (TempData["CartSuccess"] != null)
{
    <div class="alert alert-success">@TempData["CartSuccess"]</div>
}

@if (cartItems != null && cartItems.Any())
{
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:80px;"></th>
                            <th>Sản phẩm</th>
                            <th class="text-end" style="width:150px;">Đơn giá</th>
                            <th class="text-center" style="width:160px;">Số lượng</th>
                            <th class="text-end" style="width:150px;">Thành tiền</th>
                            <th style="width:60px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in cartItems)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="" class="rounded" style="width:60px;height:60px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:60px;height:60px;">
                                            <i class="fas fa-desktop text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Detail", "Shop", new { id = item.ProductId })" class="text-decoration-none fw-semibold text-dark">
                                        @item.ProductName
                                    </a>
                                </td>
                                <td class="text-end">@item.Price.ToString("#,0") ₫</td>
                                <td class="text-center">
                                    <form method="post" action="@Url.Action("UpdateQuantity", "Cart")" class="d-inline-flex align-items-center justify-content-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <div class="input-group input-group-sm" style="width:120px;">
                                            <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="btn btn-outline-secondary">−</button>
                                            <input type="text" class="form-control text-center" value="@item.Quantity" readonly />
                                            <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="btn btn-outline-secondary">+</button>
                                        </div>
                                    </form>
                                </td>
                                <td class="text-end fw-semibold">@((item.Price * item.Quantity).ToString("#,0")) ₫</td>
                                <td>
                                    <form method="post" action="@Url.Action("Remove", "Cart")">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Total & Actions -->
    <div class="row mt-4">
        <div class="col-md-6">
            <a href="@Url.Action("Index", "Shop")" class="btn btn-outline-dark">
                <i class="fas fa-arrow-left me-1"></i>Tiếp tục mua hàng
            </a>
        </div>
        <div class="col-md-6 text-end">
            <div class="bg-white rounded-3 shadow-sm p-3 d-inline-block">
                <span class="fs-5 me-3">Tổng cộng: <strong class="text-danger">@total.ToString("#,0") ₫</strong></span>
                <a href="@Url.Action("Checkout", "Cart")" class="btn btn-dark btn-lg px-4">
                    <i class="fas fa-credit-card me-1"></i>Thanh toán
                </a>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
        <h5 class="text-muted">Giỏ hàng trống</h5>
        <p class="text-muted">Bạn chưa có sản phẩm nào trong giỏ hàng.</p>
        <a href="@Url.Action("Index", "Shop")" class="btn btn-dark mt-2">
            <i class="fas fa-store me-1"></i>Đến cửa hàng
        </a>
    </div>
}
