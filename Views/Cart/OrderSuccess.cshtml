@{
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<div class="text-center py-5">
    <div class="mb-4">
        <i class="fas fa-check-circle fa-5x" style="color:#28a745;"></i>
    </div>
    <h3 class="fw-bold mb-3">Đặt hàng thành công!</h3>
    @if (ViewBag.OrderCode != null)
    {
        <p class="fs-5 text-muted">@ViewBag.OrderCode</p>
    }
    <p class="text-muted">Cảm ơn bạn đã mua hàng tại Desktop Shop.<br />Chúng tôi sẽ liên hệ để xác nhận đơn hàng sớm nhất.</p>
    <a href="@Url.Action("Index", "Shop")" class="btn btn-dark btn-lg mt-3">
        <i class="fas fa-store me-1"></i>Tiếp tục mua hàng
    </a>
</div>
