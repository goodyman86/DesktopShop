using System;
using System.Collections.Generic;
using System.Configuration;
using System.Data.SqlClient;
using System.Linq;
using System.Web;
using System.Web.Mvc;
using DesktopShop.Domain.Entities;
using DesktopShop.Domain.Enums;
using DesktopShop.Infrastructure.Data;
using Microsoft.EntityFrameworkCore;

namespace WebApplication1.Controllers
{
    public class CartItem
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; }
        public decimal Price { get; set; }
        public int Quantity { get; set; }
        public string ImageUrl { get; set; }
    }

    public class CartController : Controller
    {
        private const string CartSessionKey = "ShoppingCart";

        private ApplicationDbContext CreateDbContext()
        {
            var connectionString = ConfigurationManager.ConnectionStrings["DefaultConnection"].ConnectionString;
            var connection = new SqlConnection(connectionString);
            var optionsBuilder = new DbContextOptionsBuilder<ApplicationDbContext>();
            optionsBuilder.UseSqlServer(connection);
            return new ApplicationDbContext(optionsBuilder.Options);
        }

        private List<CartItem> GetCart()
        {
            var cart = Session[CartSessionKey] as List<CartItem>;
            if (cart == null)
            {
                cart = new List<CartItem>();
                Session[CartSessionKey] = cart;
            }
            return cart;
        }

        private void SaveCart(List<CartItem> cart)
        {
            Session[CartSessionKey] = cart;
        }

        public ActionResult Index()
        {
            ViewBag.Title = "Giỏ hàng";
            var cart = GetCart();
            ViewBag.CartItems = cart;
            ViewBag.Total = cart.Sum(x => x.Price * x.Quantity);
            return View();
        }

        [HttpPost]
        public ActionResult Add(int productId, int quantity = 1)
        {
            using (var context = CreateDbContext())
            {
                var product = context.Products.FirstOrDefault(p => p.Id == productId && p.IsActive);
                if (product == null)
                {
                    TempData["CartError"] = "Sản phẩm không tồn tại.";
                    return RedirectToAction("Index", "Shop");
                }

                var cart = GetCart();
                var existing = cart.FirstOrDefault(x => x.ProductId == productId);

                if (existing != null)
                {
                    existing.Quantity += quantity;
                }
                else
                {
                    cart.Add(new CartItem
                    {
                        ProductId = product.Id,
                        ProductName = product.Name,
                        Price = product.Price,
                        Quantity = quantity,
                        ImageUrl = product.ImageUrl
                    });
                }

                SaveCart(cart);
            }

            TempData["CartSuccess"] = "Đã thêm sản phẩm vào giỏ hàng.";
            return RedirectToAction("Index");
        }

        [HttpPost]
        public ActionResult UpdateQuantity(int productId, int quantity)
        {
            var cart = GetCart();
            var item = cart.FirstOrDefault(x => x.ProductId == productId);
            if (item != null)
            {
                if (quantity <= 0)
                    cart.Remove(item);
                else
                    item.Quantity = quantity;
            }
            SaveCart(cart);
            return RedirectToAction("Index");
        }

        [HttpPost]
        public ActionResult Remove(int productId)
        {
            var cart = GetCart();
            cart.RemoveAll(x => x.ProductId == productId);
            SaveCart(cart);
            return RedirectToAction("Index");
        }

        public ActionResult Checkout()
        {
            if (Session["CustomerId"] == null)
            {
                TempData["ReturnUrl"] = Url.Action("Checkout", "Cart");
                return RedirectToAction("Login", "CustomerAuth");
            }

            var cart = GetCart();
            if (!cart.Any())
            {
                TempData["CartError"] = "Giỏ hàng trống.";
                return RedirectToAction("Index");
            }

            ViewBag.Title = "Thanh toán";
            ViewBag.CartItems = cart;
            ViewBag.Total = cart.Sum(x => x.Price * x.Quantity);

            using (var context = CreateDbContext())
            {
                var customerId = (int)Session["CustomerId"];
                var customer = context.Customers.FirstOrDefault(c => c.Id == customerId);
                if (customer != null)
                {
                    ViewBag.CustomerName = customer.FullName;
                    ViewBag.CustomerEmail = customer.Email;
                    ViewBag.CustomerPhone = customer.Phone;
                    ViewBag.CustomerAddress = customer.Address;
                }
            }

            return View();
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public ActionResult PlaceOrder(string customerName, string customerPhone,
            string customerEmail, string shippingAddress, string notes)
        {
            if (Session["CustomerId"] == null)
            {
                TempData["ReturnUrl"] = Url.Action("Checkout", "Cart");
                return RedirectToAction("Login", "CustomerAuth");
            }

            var cart = GetCart();
            if (!cart.Any())
            {
                TempData["CartError"] = "Giỏ hàng trống.";
                return RedirectToAction("Index");
            }

            using (var context = CreateDbContext())
            {
                var order = new Order
                {
                    OrderCode = "ORD-" + DateTime.Now.ToString("yyyyMMddHHmmss") + "-" + new Random().Next(100, 999),
                    CustomerName = customerName ?? "",
                    CustomerPhone = customerPhone,
                    CustomerEmail = customerEmail,
                    ShippingAddress = shippingAddress,
                    Notes = notes,
                    Status = OrderStatus.Pending,
                    CreatedByUserId = Session["CustomerId"].ToString(),
                    TotalAmount = cart.Sum(x => x.Price * x.Quantity)
                };

                foreach (var item in cart)
                {
                    order.OrderDetails.Add(new OrderDetail
                    {
                        ProductId = item.ProductId,
                        ProductName = item.ProductName,
                        UnitPrice = item.Price,
                        Quantity = item.Quantity,
                        SubTotal = item.Price * item.Quantity
                    });

                    // Update stock
                    var product = context.Products.FirstOrDefault(p => p.Id == item.ProductId);
                    if (product != null)
                    {
                        product.StockQuantity -= item.Quantity;
                        if (product.StockQuantity < 0) product.StockQuantity = 0;
                    }
                }

                context.Orders.Add(order);
                context.SaveChanges();

                // Clear cart
                Session.Remove(CartSessionKey);

                TempData["OrderSuccess"] = "Đặt hàng thành công! Mã đơn hàng: " + order.OrderCode;
            }

            return RedirectToAction("OrderSuccess");
        }

        public ActionResult OrderSuccess()
        {
            ViewBag.Title = "Đặt hàng thành công";
            ViewBag.OrderCode = TempData["OrderSuccess"];
            return View();
        }

        [HttpGet]
        public JsonResult GetCartCount()
        {
            var cart = GetCart();
            return Json(new { count = cart.Sum(x => x.Quantity) }, JsonRequestBehavior.AllowGet);
        }
    }
}
