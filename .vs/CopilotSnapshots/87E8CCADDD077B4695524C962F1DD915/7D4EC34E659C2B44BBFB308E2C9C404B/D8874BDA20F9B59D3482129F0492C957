@{
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var order = ViewBag.Order as DesktopShop.Domain.Entities.Order;

    var statusClass = "";
    var statusText = "";
    var statusIcon = "";
    switch (order.Status)
    {
        case DesktopShop.Domain.Enums.OrderStatus.Pending:
            statusClass = "bg-warning text-dark";
            statusText = "Chờ xử lý";
            statusIcon = "fas fa-clock";
            break;
        case DesktopShop.Domain.Enums.OrderStatus.Confirmed:
            statusClass = "bg-info text-white";
            statusText = "Đã xác nhận";
            statusIcon = "fas fa-check";
            break;
        case DesktopShop.Domain.Enums.OrderStatus.Completed:
            statusClass = "bg-success";
            statusText = "Hoàn thành";
            statusIcon = "fas fa-check-double";
            break;
        case DesktopShop.Domain.Enums.OrderStatus.Cancelled:
            statusClass = "bg-danger";
            statusText = "Đã hủy";
            statusIcon = "fas fa-times";
            break;
    }

    var paymentClass = "";
    var paymentText = "";
    var paymentIcon = "";
    switch (order.PaymentMethod)
    {
        case DesktopShop.Domain.Enums.PaymentMethod.CashOnDelivery:
            paymentClass = "bg-success";
            paymentText = "Thanh toán khi nhận hàng (COD)";
            paymentIcon = "fas fa-money-bill-wave";
            break;
        case DesktopShop.Domain.Enums.PaymentMethod.BankTransfer:
            paymentClass = "bg-primary";
            paymentText = "Chuyển khoản ngân hàng";
            paymentIcon = "fas fa-university";
            break;
        case DesktopShop.Domain.Enums.PaymentMethod.CreditCard:
            paymentClass = "bg-info";
            paymentText = "Thẻ tín dụng/Ghi nợ";
            paymentIcon = "fas fa-credit-card";
            break;
        case DesktopShop.Domain.Enums.PaymentMethod.EWallet:
            paymentClass = "bg-warning";
            paymentText = "Ví điện tử";
            paymentIcon = "fas fa-wallet";
            break;
    }
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("MyOrders", "CustomerAuth")">Đơn hàng của tôi</a></li>
        <li class="breadcrumb-item active">@order.OrderCode</li>
    </ol>
</nav>

@if (TempData["OrderError"] != null)
{
    <div class="alert alert-danger py-2"><i class="fas fa-exclamation-circle me-1"></i>@TempData["OrderError"]</div>
}

<div class="row g-4">
    <!-- Order Info -->
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white border-0 pt-3 pb-0 px-4">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-receipt me-2"></i>@order.OrderCode
                    </h5>
                    <span class="badge @statusClass px-3 py-2">
                        <i class="@statusIcon me-1"></i>@statusText
                    </span>
                </div>
                <small class="text-muted">
                    <i class="fas fa-calendar me-1"></i>Đặt ngày @order.CreatedAt.ToString("dd/MM/yyyy") lúc @order.CreatedAt.ToString("HH:mm")
                </small>
            </div>
            <div class="card-body p-4">
                <!-- Products table -->
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:40px;">#</th>
                                <th>Sản phẩm</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var idx = 0; }
                            @foreach (var item in order.OrderDetails)
                            {
                                idx++;
                                <tr>
                                    <td class="text-muted">@idx</td>
                                    <td class="fw-semibold">@item.ProductName</td>
                                    <td class="text-end">@item.UnitPrice.ToString("#,0") ₫</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end fw-semibold">@item.SubTotal.ToString("#,0") ₫</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="border-top">
                                <td colspan="4" class="text-end fw-bold fs-5">Tổng cộng</td>
                                <td class="text-end fw-bold fs-5" style="color:#e94560;">@order.TotalAmount.ToString("#,0") ₫</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Shipping Info -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="fas fa-truck me-2"></i>Thông tin giao hàng</h6>

                <div class="mb-2">
                    <small class="text-muted">Người nhận</small>
                    <p class="fw-semibold mb-1">@order.CustomerName</p>
                </div>

                @if (!string.IsNullOrEmpty(order.CustomerPhone))
                {
                    <div class="mb-2">
                        <small class="text-muted">Số điện thoại</small>
                        <p class="fw-semibold mb-1"><i class="fas fa-phone me-1 text-muted"></i>@order.CustomerPhone</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(order.CustomerEmail))
                {
                    <div class="mb-2">
                        <small class="text-muted">Email</small>
                        <p class="fw-semibold mb-1"><i class="fas fa-envelope me-1 text-muted"></i>@order.CustomerEmail</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(order.ShippingAddress))
                {
                    <div class="mb-2">
                        <small class="text-muted">Địa chỉ</small>
                        <p class="fw-semibold mb-1"><i class="fas fa-map-marker-alt me-1 text-muted"></i>@order.ShippingAddress</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(order.Notes))
                {
                    <div class="mb-0">
                        <small class="text-muted">Ghi chú</small>
                        <p class="mb-0"><i class="fas fa-sticky-note me-1 text-muted"></i>@order.Notes</p>
                    </div>
                }
            </div>
        </div>

        <!-- Payment Method -->
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="fas fa-credit-card me-2"></i>Phương thức thanh toán</h6>
                <div class="d-flex align-items-center">
                    <span class="badge @paymentClass text-white px-3 py-2" style="font-size: 0.9rem;">
                        <i class="@paymentIcon me-2"></i>@paymentText
                    </span>
                </div>
            </div>
        </div>

        <!-- Back button -->
        <div class="mt-3">
            <a href="@Url.Action("MyOrders", "CustomerAuth")" class="btn btn-outline-dark w-100">
                <i class="fas fa-arrow-left me-1"></i>Quay lại danh sách đơn hàng
            </a>
        </div>

        @if (order.Status == DesktopShop.Domain.Enums.OrderStatus.Pending)
        {
            <div class="mt-2">
                <form method="post" action="@Url.Action("CancelOrder", "CustomerAuth")" onsubmit="return confirm('Bạn có chắc muốn hủy đơn hàng này?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@order.Id" />
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="fas fa-times me-1"></i>Hủy đơn hàng
                    </button>
                </form>
            </div>
        }
    </div>
</div>
