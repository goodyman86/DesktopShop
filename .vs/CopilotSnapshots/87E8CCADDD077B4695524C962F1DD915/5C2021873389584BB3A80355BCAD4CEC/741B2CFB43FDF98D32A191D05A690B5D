@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section styles {
    <style>
        /* Increase font size to 14px for Orders page */
        .page-header h1,
        .page-header p,
        .filter-bar,
        .filter-bar input,
        .filter-bar .btn-outline-modern,
        .table-modern,
        .table-modern th,
        .table-modern td,
        .modal-body,
        .form-select {
            font-size: 14px !important;
        }

        /* Adjust icon sizes proportionally */
        .table-modern i {
            font-size: 13px;
        }

        /* Modal content */
        #orderDetailContent .text-muted,
        #orderDetailContent strong,
        #orderDetailContent span {
            font-size: 14px !important;
        }
    </style>
}

<div class="page-header">
    <h1><i class="fa-solid fa-clipboard-list me-2"></i>Quản lý Đơn Hàng</h1>
    <p>Theo dõi và quản lý tất cả đơn hàng</p>
</div>

<!-- Filter -->
<div class="filter-bar mb-3">
    <div class="search-input-wrapper">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="orderSearch" class="search-input" placeholder="Tìm theo mã đơn hoặc tên khách..." />
    </div>

    <!-- Date Range Filter -->
    <div style="display: flex; align-items: center; gap: 8px;">
        <i class="fa-solid fa-calendar-days text-muted"></i>
        <input type="date" id="dateFrom" class="form-control form-control-sm" style="width: 150px; font-size: 0.85rem;" title="Từ ngày" />
        <span class="text-muted">→</span>
        <input type="date" id="dateTo" class="form-control form-control-sm" style="width: 150px; font-size: 0.85rem;" title="Đến ngày" />
        <button class="btn btn-sm btn-outline-modern" id="btnClearDate" title="Xóa lọc ngày">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>

    <div class="filter-buttons">
        <button class="btn-outline-modern active" data-status="-1">Tất cả</button>
        <button class="btn-outline-modern" data-status="0"><i class="fa-solid fa-clock me-1"></i>Chờ xử lý</button>
        <button class="btn-outline-modern" data-status="1"><i class="fa-solid fa-check me-1"></i>Đã xác nhận</button>
        <button class="btn-outline-modern" data-status="2"><i class="fa-solid fa-circle-check me-1"></i>Hoàn thành</button>
        <button class="btn-outline-modern" data-status="3"><i class="fa-solid fa-ban me-1"></i>Đã hủy</button>
    </div>
</div>

<!-- Orders Table -->
<div class="card-panel">
    <div class="card-panel-body p-0 table-scroll-container">
        <table class="table-modern">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>SĐT</th>
                    <th class="text-end">Tổng tiền</th>
                    <th>Thanh toán</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Ghi chú</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody id="ordersTableBody">
                <tr><td colspan="9" class="text-center py-4 text-muted">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Order Detail Modal -->
<div class="modal fade" id="orderDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:var(--radius);border:none;box-shadow:var(--shadow-lg);">
            <div class="modal-header" style="border-bottom:1px solid var(--gray-200);padding:16px 24px;">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-file-invoice me-2"></i>Chi tiết đơn hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <!-- Loading -->
                <div id="orderDetailLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Đang tải...</span></div>
                </div>
                <!-- Content -->
                <div id="orderDetailContent" style="display:none;">
                    <!-- Order info -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="p-3" style="background:var(--gray-50);border-radius:8px;">
                                <div class="mb-2"><span class="text-muted" style="font-size:.8rem;">Mã đơn hàng</span><br/><strong id="od_code" style="font-size:1.05rem;"></strong></div>
                                <div class="mb-2"><span class="text-muted" style="font-size:.8rem;">Ngày tạo</span><br/><span id="od_date"></span></div>
                                <div class="mb-2"><span class="text-muted" style="font-size:.8rem;">Trạng thái</span><br/><span id="od_status"></span></div>
                                <div><span class="text-muted" style="font-size:.8rem;">Thanh toán</span><br/><span id="od_payment"></span></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3" style="background:var(--gray-50);border-radius:8px;">
                                <div class="mb-2"><span class="text-muted" style="font-size:.8rem;">Khách hàng</span><br/><strong id="od_customer"></strong></div>
                                <div class="mb-2"><span class="text-muted" style="font-size:.8rem;">Số điện thoại</span><br/><span id="od_phone"></span></div>
                                <div><span class="text-muted" style="font-size:.8rem;">Ghi chú</span><br/><span id="od_notes" class="fst-italic"></span></div>
                            </div>
                        </div>
                    </div>
                    <!-- Order items table -->
                    <h6 class="fw-bold mb-2"><i class="fa-solid fa-box-open me-1"></i>Sản phẩm trong đơn</h6>
                    <table class="table-modern" style="margin-bottom:0;">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Tên sản phẩm</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody id="od_items"></tbody>
                        <tfoot>
                            <tr style="background:var(--gray-50);">
                                <td colspan="4" class="text-end fw-bold" style="font-size:.9rem;">Tổng cộng:</td>
                                <td class="text-end fw-bold text-danger" style="font-size:1.05rem;" id="od_total"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--gray-200);padding:12px 24px;">
                <button type="button" class="btn btn-outline-modern" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(function () {
            var API = '/api';
            var orders = [];
            var filterStatus = -1;
            var detailModal = new bootstrap.Modal(document.getElementById('orderDetailModal'));

            function loadOrders() {
                console.log('Loading orders from:', API + '/orders');
                $.getJSON(API + '/orders')
                    .done(function (data) {
                        console.log('Orders received:', data);
                        orders = Array.isArray(data) ? data : (data.data || []);
                        console.log('Processed orders:', orders);
                        renderTable();
                    })
                    .fail(function (jqXHR, textStatus, errorThrown) {
                        console.error('API Error:', textStatus, errorThrown);
                        console.error('Response:', jqXHR.responseText);
                        $('#ordersTableBody').html('<tr><td colspan="9" class="text-center py-4 text-danger">Không thể tải dữ liệu. Lỗi: ' + textStatus + '</td></tr>');
                    });
            }

            function renderTable() {
                console.log('renderTable called, orders count:', orders.length);
                var keyword = $.trim($('#orderSearch').val()).toLowerCase();
                var dateFrom = $('#dateFrom').val();
                var dateTo = $('#dateTo').val();

                console.log('Filters - Status:', filterStatus, 'Keyword:', keyword, 'DateFrom:', dateFrom, 'DateTo:', dateTo);

                var filtered = orders.filter(function (o) {
                    // Status filter
                    var status = o.status;
                    var matchStatus = filterStatus === -1 || status === filterStatus;

                    // Search filter
                    var code = (o.orderCode || '').toLowerCase();
                    var name = (o.customerName || '').toLowerCase();
                    var matchSearch = !keyword || code.indexOf(keyword) >= 0 || name.indexOf(keyword) >= 0;

                    // Date range filter
                    var matchDate = true;
                    if (dateFrom || dateTo) {
                        var orderDate = new Date(o.createdAt);
                        var orderDateOnly = new Date(orderDate.getFullYear(), orderDate.getMonth(), orderDate.getDate());

                        if (dateFrom) {
                            var fromDate = new Date(dateFrom);
                            if (orderDateOnly < fromDate) matchDate = false;
                        }

                        if (dateTo) {
                            var toDate = new Date(dateTo);
                            if (orderDateOnly > toDate) matchDate = false;
                        }
                    }

                    return matchStatus && matchSearch && matchDate;
                });

                console.log('Filtered orders count:', filtered.length);

                if (!filtered.length) {
                    $('#ordersTableBody').html('<tr><td colspan="9" class="text-center py-4 text-muted">Không tìm thấy đơn hàng</td></tr>');
                    return;
                }

                var html = '';
                filtered.forEach(function (o) {
                    html += '<tr data-id="' + o.id + '">' +
                        '<td class="fw-semibold">' + (o.orderCode || '#' + o.id) + '</td>' +
                        '<td>' + o.customerName + '</td>' +
                        '<td class="text-muted">' + (o.customerPhone || '-') + '</td>' +
                        '<td class="text-end text-danger fw-bold">' + formatVND(o.totalAmount) + '</td>' +
                        '<td>' + getPaymentMethodBadge(o.paymentMethod) + '</td>' +
                        '<td>' + buildStatusSelect(o.id, o.status) + '</td>' +
                        '<td class="text-muted">' + formatDate(o.createdAt) + '</td>' +
                        '<td class="text-muted" style="max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="' + (o.notes || '') + '">' + (o.notes || '-') + '</td>' +
                        '<td class="text-center">' +
                            '<button class="btn btn-sm btn-outline-modern btn-view-detail me-1" title="Chi tiết"><i class="fa-solid fa-eye"></i></button>' +
                            '<button class="btn btn-sm btn-outline-modern text-danger btn-delete-order" title="Xóa"><i class="fa-solid fa-trash"></i></button>' +
                        '</td>' +
                        '</tr>';
                });
                $('#ordersTableBody').html(html);
            }

            /* ── Build status dropdown ── */
            var statusOptions = [
                { value: 0, text: 'Chờ xử lý',   css: 'badge-pending' },
                { value: 1, text: 'Đã xác nhận', css: 'badge-confirmed' },
                { value: 2, text: 'Hoàn thành',  css: 'badge-completed' },
                { value: 3, text: 'Đã hủy',      css: 'badge-cancelled' }
            ];

            function buildStatusSelect(orderId, currentStatus) {
                var html = '<select class="form-select form-select-sm status-select" data-order-id="' + orderId + '" style="width:auto;min-width:130px;font-size:.8rem;font-weight:600;border-radius:6px;padding:4px 28px 4px 8px;">';
                statusOptions.forEach(function (s) {
                    html += '<option value="' + s.value + '"' + (s.value === currentStatus ? ' selected' : '') + '>' + s.text + '</option>';
                });
                html += '</select>';
                return html;
            }

            /* ── Update status on change ── */
            $(document).on('change', '.status-select', function () {
                var $sel = $(this);
                var orderId = $sel.data('order-id');
                var newStatus = parseInt($sel.val());
                var statusText = statusOptions.find(function (s) { return s.value === newStatus; }).text;

                Swal.fire({
                    title: 'Cập nhật trạng thái?',
                    html: 'Chuyển trạng thái đơn hàng sang <b>' + statusText + '</b>?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: '<i class="fa-solid fa-check me-1"></i>Cập nhật',
                    cancelButtonText: 'Hủy',
                    confirmButtonColor: '#1a73e8'
                }).then(function (result) {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: API + '/orders/' + orderId + '/status',
                            type: 'PATCH',
                            contentType: 'application/json',
                            data: JSON.stringify({ status: newStatus })
                        }).done(function () {
                            showToast('success', 'Đã cập nhật trạng thái thành công!');
                            loadOrders();
                        }).fail(function () {
                            showToast('error', 'Không thể cập nhật trạng thái');
                            loadOrders();
                        });
                    } else {
                        // Revert selection
                        loadOrders();
                    }
                });
            });

            /* ── View order detail ── */
            $(document).on('click', '.btn-view-detail', function () {
                var id = $(this).closest('tr').data('id');
                if (!id) return;

                $('#orderDetailLoading').show();
                $('#orderDetailContent').hide();
                detailModal.show();

                $.getJSON(API + '/orders/' + id)
                    .done(function (o) {
                        $('#od_code').text(o.orderCode || '#' + o.id);
                        $('#od_date').text(formatDate(o.createdAt));
                        $('#od_status').html(getStatusBadge(o.status));
                        $('#od_payment').html(getPaymentMethodBadge(o.paymentMethod));
                        $('#od_customer').text(o.customerName);
                        $('#od_phone').text(o.customerPhone || '-');
                        $('#od_notes').text(o.notes || 'Không có');

                        var items = o.orderDetails || [];
                        var html = '';
                        items.forEach(function (item, idx) {
                            html += '<tr>' +
                                '<td class="text-muted">' + (idx + 1) + '</td>' +
                                '<td class="fw-semibold">' + item.productName + '</td>' +
                                '<td class="text-end">' + formatVND(item.unitPrice) + '</td>' +
                                '<td class="text-center">' + item.quantity + '</td>' +
                                '<td class="text-end text-danger fw-semibold">' + formatVND(item.subTotal) + '</td>' +
                                '</tr>';
                        });
                        if (!items.length) {
                            html = '<tr><td colspan="5" class="text-center text-muted py-3">Không có sản phẩm</td></tr>';
                        }
                        $('#od_items').html(html);
                        $('#od_total').text(formatVND(o.totalAmount));

                        $('#orderDetailLoading').hide();
                        $('#orderDetailContent').show();
                    })
                    .fail(function () {
                        $('#orderDetailLoading').hide();
                        $('#orderDetailContent').html('<div class="text-center text-danger py-4"><i class="fa-solid fa-triangle-exclamation me-1"></i>Không thể tải chi tiết đơn hàng</div>').show();
                    });
            });

            /* ── Delete order ── */
            $(document).on('click', '.btn-delete-order', function () {
                var id = $(this).closest('tr').data('id');
                var o = orders.find(function (x) { return x.id === id; });
                if (!o) return;

                Swal.fire({
                    title: 'Xác nhận xóa đơn hàng?',
                    html: 'Đơn hàng <b>' + (o.orderCode || '#' + o.id) + '</b> sẽ bị xóa vĩnh viễn.<br/>Số lượng tồn kho sẽ được hoàn lại.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#e02424',
                    confirmButtonText: '<i class="fa-solid fa-trash me-1"></i>Xóa',
                    cancelButtonText: 'Hủy'
                }).then(function (result) {
                    if (!result.isConfirmed) return;
                    $.ajax({
                        url: API + '/orders/' + id,
                        type: 'DELETE'
                    }).done(function () {
                        Swal.fire({ icon: 'success', title: 'Đã xóa!', text: 'Đơn hàng đã được xóa và tồn kho đã hoàn lại.', timer: 1500, showConfirmButton: false });
                        loadOrders();
                    }).fail(function () {
                        Swal.fire('Lỗi', 'Không thể xóa đơn hàng này.', 'error');
                    });
                });
            });

            // Status filter
            $(document).on('click', '.filter-buttons .btn-outline-modern', function () {
                $('.filter-buttons .btn-outline-modern').removeClass('active');
                $(this).addClass('active');
                filterStatus = parseInt($(this).data('status'));
                renderTable();
            });

            $('#orderSearch').on('input', function () { renderTable(); });

            // Date range filter events
            $('#dateFrom, #dateTo').on('change', function () { renderTable(); });

            $('#btnClearDate').on('click', function () {
                $('#dateFrom').val('');
                $('#dateTo').val('');
                renderTable();
            });

            loadOrders();
        });
    </script>
}
