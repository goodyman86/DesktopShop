@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h1><i class="fa-solid fa-computer me-2"></i>Quản lý Sản Phẩm</h1>
        <p>
            Danh sách tất cả Desktop Computer trong kho hàng
            <span id="productCount" class="badge" style="background: var(--primary-light); color: var(--primary); font-weight: 600; margin-left: 8px; padding: 4px 10px; border-radius: 8px;">
                <i class="fa-solid fa-box me-1"></i><span id="productCountNumber">0</span> sản phẩm
            </span>
        </p>
    </div>
    <button class="btn btn-primary-modern" id="btnAddProduct">
        <i class="fa-solid fa-plus me-1"></i>Thêm sản phẩm
    </button>
</div>

<!-- Filter -->
<div class="filter-bar mb-3">
    <div class="search-input-wrapper">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="productSearch" class="search-input" placeholder="Tìm kiếm sản phẩm..." />
    </div>
    <select id="categorySelect" class="form-select" style="width:auto;border-radius:8px;font-size:.875rem;font-family:'Inter',sans-serif;">
        <option value="0">Tất cả danh mục</option>
    </select>
    <select id="priceSort" class="form-select" style="width:auto;border-radius:8px;font-size:.875rem;font-family:'Inter',sans-serif;">
        <option value="0">Sắp xếp giá</option>
        <option value="asc">Giá tăng dần</option>
        <option value="desc">Giá giảm dần</option>
    </select>
</div>

<!-- Product Table -->
<div class="card-panel">
    <div class="card-panel-body p-0 table-scroll-container">
        <table class="table-modern">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th>CPU</th>
                    <th>RAM</th>
                    <th class="text-end" id="thPrice" style="cursor:pointer;user-select:none" title="Nhấn để sắp xếp theo giá">Giá <i class="fa-solid fa-sort" style="font-size:.7rem;opacity:.5"></i></th>
                    <th class="text-center">Kho</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody id="productsTableBody">
                <tr><td colspan="10" class="text-center py-4 text-muted">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Product Modal (Add / Edit) -->
<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:var(--radius);border:none;box-shadow:var(--shadow-lg);">
            <div class="modal-header" style="border-bottom:1px solid var(--gray-200);padding:16px 24px;">
                <h5 class="modal-title fw-bold" id="productModalTitle">Thêm sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <form id="productForm" autocomplete="off">
                    <input type="hidden" id="pf_id" />

                    <!-- Row 1: Name + Category -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Tên sản phẩm <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="pf_name" required placeholder="VD: ASUS ROG Strix G15" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Danh mục <span class="text-danger">*</span></label>
                            <select class="form-select" id="pf_category" required></select>
                        </div>
                    </div>

                    <!-- Row 2: CPU + RAM + GPU + Storage -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">CPU</label>
                            <input type="text" class="form-control" id="pf_cpu" placeholder="i7-13700K" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">RAM</label>
                            <input type="text" class="form-control" id="pf_ram" placeholder="32GB DDR5" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">GPU</label>
                            <input type="text" class="form-control" id="pf_gpu" placeholder="RTX 4070 Ti" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Ổ cứng</label>
                            <input type="text" class="form-control" id="pf_storage" placeholder="1TB NVMe SSD" />
                        </div>
                    </div>

                    <!-- Row 3: Price + Stock + MinStock + IsActive -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Giá (VNĐ) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="pf_price" required min="0" step="1" placeholder="35500000" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Tồn kho <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="pf_stock" required min="0" value="0" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Tồn kho tối thiểu</label>
                            <input type="number" class="form-control" id="pf_minStock" min="0" value="5" />
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <div class="form-check form-switch" style="padding-bottom:8px;">
                                <input class="form-check-input" type="checkbox" id="pf_active" checked />
                                <label class="form-check-label fw-semibold" for="pf_active" style="font-size:.8rem;">Hoạt động</label>
                            </div>
                        </div>
                    </div>

                    <!-- Row 4: Image upload -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="font-size:.8rem;">Hình ảnh sản phẩm</label>
                        <div class="d-flex align-items-start gap-3">
                            <div id="pf_imagePreview" style="width:100px;height:100px;border-radius:8px;border:2px dashed var(--gray-300);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;background:var(--gray-50);cursor:pointer;" title="Nhấn để chọn ảnh">
                                <i class="fa-solid fa-cloud-arrow-up text-muted" style="font-size:1.5rem;"></i>
                            </div>
                            <div class="flex-fill">
                                <input type="file" class="form-control" id="pf_imageFile" accept=".jpg,.jpeg,.png,.webp" style="font-size:.85rem;" />
                                <input type="hidden" id="pf_imageUrl" />
                                <div class="form-text">Chấp nhận: .jpg, .jpeg, .png, .webp (tối đa 5MB)</div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 5: Description -->
                    <div class="mb-0">
                        <label class="form-label fw-semibold" style="font-size:.8rem;">Mô tả</label>
                        <textarea class="form-control" id="pf_desc" rows="3" placeholder="Mô tả chi tiết sản phẩm..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--gray-200);padding:16px 24px;">
                <button type="button" class="btn btn-outline-modern" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary-modern" id="btnSaveProduct">
                    <i class="fa-solid fa-floppy-disk me-1"></i><span id="btnSaveText">Lưu sản phẩm</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(function () {
            var API = '/api';
            var products = [];
            var categories = [];
            var editingId = 0;
            var modal = new bootstrap.Modal(document.getElementById('productModal'));

            /* ── Load data ── */
            function loadAll() {
                $.when(
                    $.getJSON(API + '/products'),
                    $.getJSON(API + '/categories')
                ).done(function (pRes, cRes) {
                    products = Array.isArray(pRes[0]) ? pRes[0] : (pRes[0].data || []);
                    categories = Array.isArray(cRes[0]) ? cRes[0] : (cRes[0].data || []);
                    renderCategorySelect();
                    renderCategoryOptions();
                    renderTable();
                }).fail(function (jqXHR, textStatus, errorThrown) {
                    console.error('Load products failed:', textStatus, errorThrown);
                    $('#productsTableBody').html('<tr><td colspan="10" class="text-center py-4 text-danger">Không thể tải dữ liệu</td></tr>');
                });
            }

            /* ── Render filter category select ── */
            function renderCategorySelect() {
                var $sel = $('#categorySelect');
                $sel.find('option:not(:first)').remove();
                categories.forEach(function (c) {
                    $sel.append('<option value="' + c.id + '">' + c.name + '</option>');
                });
            }

            /* ── Render modal category options ── */
            function renderCategoryOptions() {
                var $sel = $('#pf_category');
                $sel.empty();
                $sel.append('<option value="">-- Chọn danh mục --</option>');
                categories.forEach(function (c) {
                    $sel.append('<option value="' + c.id + '">' + c.name + '</option>');
                });
            }

            var currentSort = '0'; // '0' = none, 'asc', 'desc'

            /* ── Render product table ── */
            function renderTable() {
                var keyword = $.trim($('#productSearch').val()).toLowerCase();
                var catId = parseInt($('#categorySelect').val()) || 0;
                var sortDir = $('#priceSort').val() || currentSort;

                var filtered = products.filter(function (p) {
                    var matchCat = catId === 0 || p.categoryId === catId;
                    var matchSearch = !keyword || (p.name || '').toLowerCase().indexOf(keyword) >= 0;
                    return matchCat && matchSearch;
                });

                // Sort by price
                if (sortDir === 'asc') {
                    filtered.sort(function (a, b) { return (a.price || 0) - (b.price || 0); });
                } else if (sortDir === 'desc') {
                    filtered.sort(function (a, b) { return (b.price || 0) - (a.price || 0); });
                }

                // Update sort icon
                var $icon = $('#thPrice i');
                $icon.removeClass('fa-sort fa-sort-up fa-sort-down').css('opacity', '.5');
                if (sortDir === 'asc') {
                    $icon.addClass('fa-sort-up').css('opacity', '1');
                } else if (sortDir === 'desc') {
                    $icon.addClass('fa-sort-down').css('opacity', '1');
                } else {
                    $icon.addClass('fa-sort');
                }

                if (!filtered.length) {
                    $('#productsTableBody').html('<tr><td colspan="10" class="text-center py-4 text-muted">Không tìm thấy sản phẩm</td></tr>');
                    return;
                }

                var html = '';
                filtered.forEach(function (p) {
                    var stock = p.stockQuantity;
                    var minStock = p.minStockLevel || 3;
                    var stockClass = stock <= 0 ? 'text-danger fw-bold' : (stock <= minStock ? 'text-warning fw-bold' : '');

                    html += '<tr data-id="' + p.id + '">' +
                        '<td class="text-muted">#' + p.id + '</td>' +
                        '<td>' + (p.imageUrl ? '<img src="' + p.imageUrl + '" style="width:40px;height:40px;border-radius:6px;object-fit:cover" />' : '<i class="fa-solid fa-image text-muted"></i>') + '</td>' +
                        '<td class="fw-semibold">' + p.name + '</td>' +
                        '<td>' + (p.categoryName || '') + '</td>' +
                        '<td class="text-muted">' + (p.cpu || '-') + '</td>' +
                        '<td class="text-muted">' + (p.ram || '-') + '</td>' +
                        '<td class="text-end text-danger fw-bold">' + formatVND(p.price) + '</td>' +
                        '<td class="text-center ' + stockClass + '">' + stock + '</td>' +
                        '<td>' + (p.isActive !== false ? '<span class="badge-status badge-completed">Hoạt động</span>' : '<span class="badge-status badge-cancelled">Ẩn</span>') + '</td>' +
                        '<td class="text-center">' +
                            '<button class="btn btn-sm btn-outline-modern me-1 btn-edit" title="Sửa"><i class="fa-solid fa-pen"></i></button>' +
                            '<button class="btn btn-sm btn-outline-modern text-danger btn-delete" title="Xóa"><i class="fa-solid fa-trash"></i></button>' +
                        '</td>' +
                        '</tr>';
                });
                $('#productsTableBody').html(html);
            }

            /* ── Filter & Sort events ── */
            $('#productSearch').on('input', function () { renderTable(); });
            $('#categorySelect').on('change', function () { renderTable(); });
            $('#priceSort').on('change', function () {
                currentSort = $(this).val();
                renderTable();
            });
            $('#thPrice').on('click', function () {
                // Cycle: none → asc → desc → none
                if (currentSort === '0') currentSort = 'asc';
                else if (currentSort === 'asc') currentSort = 'desc';
                else currentSort = '0';
                $('#priceSort').val(currentSort);
                renderTable();
            });

            /* ── Image preview ── */
            $('#pf_imageFile').on('change', function () {
                var file = this.files[0];
                if (!file) return;
                if (file.size > 5 * 1024 * 1024) {
                    Swal.fire('Lỗi', 'File ảnh không được vượt quá 5MB.', 'error');
                    this.value = '';
                    return;
                }
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#pf_imagePreview').html('<img src="' + e.target.result + '" style="width:100%;height:100%;object-fit:cover;" />');
                };
                reader.readAsDataURL(file);
            });

            $('#pf_imagePreview').on('click', function () {
                $('#pf_imageFile').trigger('click');
            });

            /* ── Open Add modal ── */
            $('#btnAddProduct').on('click', function () {
                editingId = 0;
                $('#productModalTitle').text('Thêm sản phẩm mới');
                $('#btnSaveText').text('Thêm sản phẩm');
                resetForm();
                modal.show();
            });

            /* ── Open Edit modal ── */
            $(document).on('click', '.btn-edit', function () {
                var id = $(this).closest('tr').data('id');
                var p = products.find(function (x) { return x.id === id; });
                if (!p) return;

                editingId = p.id;
                $('#productModalTitle').text('Cập nhật sản phẩm');
                $('#btnSaveText').text('Cập nhật');
                resetForm();

                $('#pf_id').val(p.id);
                $('#pf_name').val(p.name);
                $('#pf_category').val(p.categoryId);
                $('#pf_cpu').val(p.cpu || '');
                $('#pf_ram').val(p.ram || '');
                $('#pf_gpu').val(p.gpu || '');
                $('#pf_storage').val(p.storage || '');
                $('#pf_price').val(p.price);
                $('#pf_stock').val(p.stockQuantity);
                $('#pf_minStock').val(p.minStockLevel);
                $('#pf_active').prop('checked', p.isActive !== false);
                $('#pf_imageUrl').val(p.imageUrl || '');
                $('#pf_desc').val(p.description || '');

                if (p.imageUrl) {
                    $('#pf_imagePreview').html('<img src="' + p.imageUrl + '" style="width:100%;height:100%;object-fit:cover;" />');
                }

                modal.show();
            });

            /* ── Save (Create / Update) ── */
            $('#btnSaveProduct').on('click', function () {
                if (!$('#productForm')[0].checkValidity()) {
                    $('#productForm')[0].reportValidity();
                    return;
                }

                var $btn = $(this);
                $btn.prop('disabled', true);
                $('#btnSaveText').text('Đang lưu...');

                var fileInput = $('#pf_imageFile')[0];
                if (fileInput.files.length > 0) {
                    uploadImageThenSave($btn);
                } else {
                    saveProduct($btn);
                }
            });

            function uploadImageThenSave($btn) {
                var formData = new FormData();
                formData.append('file', $('#pf_imageFile')[0].files[0]);

                $.ajax({
                    url: API + '/products/upload-image',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false
                }).done(function (res) {
                    $('#pf_imageUrl').val(res.imageUrl);
                    saveProduct($btn);
                }).fail(function (xhr) {
                    $btn.prop('disabled', false);
                    $('#btnSaveText').text(editingId ? 'Cập nhật' : 'Thêm sản phẩm');
                    Swal.fire('Lỗi', 'Upload ảnh thất bại: ' + (xhr.responseJSON && xhr.responseJSON.message || 'Lỗi không xác định'), 'error');
                });
            }

            function saveProduct($btn) {
                var dto = {
                    name: $.trim($('#pf_name').val()),
                    categoryId: parseInt($('#pf_category').val()),
                    cpu: $.trim($('#pf_cpu').val()) || null,
                    ram: $.trim($('#pf_ram').val()) || null,
                    gpu: $.trim($('#pf_gpu').val()) || null,
                    storage: $.trim($('#pf_storage').val()) || null,
                    price: parseFloat($('#pf_price').val()) || 0,
                    stockQuantity: parseInt($('#pf_stock').val()) || 0,
                    minStockLevel: parseInt($('#pf_minStock').val()) || 5,
                    imageUrl: $.trim($('#pf_imageUrl').val()) || null,
                    description: $.trim($('#pf_desc').val()) || null
                };

                var isEdit = editingId > 0;
                if (isEdit) {
                    dto.id = editingId;
                    dto.isActive = $('#pf_active').prop('checked');
                }

                $.ajax({
                    url: isEdit ? (API + '/products/' + editingId) : (API + '/products'),
                    type: isEdit ? 'PUT' : 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(dto)
                }).done(function () {
                    modal.hide();
                    Swal.fire({ icon: 'success', title: isEdit ? 'Đã cập nhật!' : 'Đã thêm!', text: 'Sản phẩm đã được lưu thành công.', timer: 1500, showConfirmButton: false });
                    loadAll();
                }).fail(function (xhr) {
                    var msg = 'Lỗi không xác định';
                    if (xhr.responseJSON) msg = xhr.responseJSON.message || xhr.responseJSON.error || JSON.stringify(xhr.responseJSON);
                    Swal.fire('Lỗi', msg, 'error');
                }).always(function () {
                    $btn.prop('disabled', false);
                    $('#btnSaveText').text(isEdit ? 'Cập nhật' : 'Thêm sản phẩm');
                });
            }

            /* ── Delete ── */
            $(document).on('click', '.btn-delete', function () {
                var id = $(this).closest('tr').data('id');
                var p = products.find(function (x) { return x.id === id; });
                if (!p) return;

                Swal.fire({
                    title: 'Xác nhận xóa?',
                    html: 'Bạn có chắc muốn xóa sản phẩm <b>' + p.name + '</b>?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#e02424',
                    confirmButtonText: 'Xóa',
                    cancelButtonText: 'Hủy'
                }).then(function (result) {
                    if (!result.isConfirmed) return;
                    $.ajax({
                        url: API + '/products/' + id,
                        type: 'DELETE'
                    }).done(function () {
                        Swal.fire({ icon: 'success', title: 'Đã xóa!', timer: 1200, showConfirmButton: false });
                        loadAll();
                    }).fail(function () {
                        Swal.fire('Lỗi', 'Không thể xóa sản phẩm này.', 'error');
                    });
                });
            });

            /* ── Reset form ── */
            function resetForm() {
                $('#productForm')[0].reset();
                $('#pf_id').val('');
                $('#pf_imageUrl').val('');
                $('#pf_active').prop('checked', true);
                $('#pf_minStock').val(5);
                $('#pf_stock').val(0);
                $('#pf_imagePreview').html('<i class="fa-solid fa-cloud-arrow-up text-muted" style="font-size:1.5rem;"></i>');
            }

            /* ── Init ── */
            loadAll();
        });
    </script>
}
