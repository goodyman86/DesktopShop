@{
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="fas fa-user-circle fa-3x text-muted mb-2"></i>
                    <h4 class="fw-bold">Đăng nhập</h4>
                    <p class="text-muted small">Đăng nhập để mua hàng và theo dõi đơn hàng</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">
                        <i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error
                    </div>
                }

                <form method="post" action="@Url.Action("Login", "CustomerAuth")">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên đăng nhập</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                            <input type="text" name="username" class="form-control" placeholder="Nhập tên đăng nhập"
                                   value="@(ViewBag.Username ?? "")" required autofocus />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu" required />
                        </div>
                        <div class="text-end mt-1">
                            <a href="@Url.Action("ForgotPassword", "CustomerAuth")" class="text-decoration-none small" style="color:#e94560;">Quên mật khẩu?</a>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 fw-semibold py-2">
                        <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                    </button>
                </form>

                <div class="text-center mt-3">
                    <p class="mb-0 small">Chưa có tài khoản?
                        <a href="@Url.Action("Register", "CustomerAuth")" class="text-decoration-none fw-semibold" style="color:#e94560;">Đăng ký ngay</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
