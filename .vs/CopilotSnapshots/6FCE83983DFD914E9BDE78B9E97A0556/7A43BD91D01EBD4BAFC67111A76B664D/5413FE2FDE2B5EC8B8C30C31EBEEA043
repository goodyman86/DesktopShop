<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - DesktopShop</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- FontAwesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

    <!-- Custom Admin CSS -->
    <link rel="stylesheet" href="~/Content/admin.css" />

    @RenderSection("styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <i class="fa-solid fa-desktop"></i>
            <span>DesktopShop</span>
        </div>
        <nav class="sidebar-nav">
            <a href="@Url.Action("Index", "DashboardView")" class="sidebar-link @(ViewBag.ActivePage == "Dashboard" ? "active" : "")">
                <i class="fa-solid fa-gauge-high"></i>
                <span>Dashboard</span>
            </a>
            <a href="@Url.Action("Index", "Sales")" class="sidebar-link @(ViewBag.ActivePage == "Sales" ? "active" : "")">
                <i class="fa-solid fa-cash-register"></i>
                <span>Bán Hàng (POS)</span>
            </a>
            <a href="@Url.Action("Products", "DashboardView")" class="sidebar-link @(ViewBag.ActivePage == "Products" ? "active" : "")">
                <i class="fa-solid fa-computer"></i>
                <span>Sản Phẩm</span>
            </a>
            <a href="@Url.Action("Orders", "DashboardView")" class="sidebar-link @(ViewBag.ActivePage == "Orders" ? "active" : "")">
                <i class="fa-solid fa-clipboard-list"></i>
                <span>Đơn Hàng</span>
            </a>
            <a href="@Url.Action("Categories", "DashboardView")" class="sidebar-link @(ViewBag.ActivePage == "Categories" ? "active" : "")">
                <i class="fa-solid fa-tags"></i>
                <span>Danh Mục</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="@Url.Action("Index", "Home")" class="sidebar-link">
                <i class="fa-solid fa-arrow-left"></i>
                <span>Về Trang Chủ</span>
            </a>
            <a href="@Url.Action("Logout", "Auth")" class="sidebar-link" style="color:var(--danger)" onclick="return confirm('Bạn có chắc muốn đăng xuất?')">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Đăng xuất</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
        <!-- Top Navbar -->
        <header class="topbar">
            <button class="btn btn-link sidebar-toggle" id="sidebarToggle">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="topbar-right">
                <span class="topbar-clock" id="topbarClock"></span>
                <div class="topbar-user">
                    <i class="fa-solid fa-circle-user"></i>
                    <span>Admin</span>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-content">
            @RenderBody()
        </main>
    </div>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap 5 Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- jsPDF (for dashboard PDF export) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.2/jspdf.umd.min.js"></script>

    <!-- Shared JS Utilities -->
    <script src="~/Scripts/app/helpers.js"></script>
    <script src="~/Scripts/app/layout.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>
