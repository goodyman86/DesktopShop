using System.Web.Http;
using DesktopShop.Application.DTOs.Order;
using DesktopShop.Application.Interfaces;
using System;
using System.Collections.Generic;
using System.Threading.Tasks;

namespace DesktopShop.API.Controllers
{
    [RoutePrefix("api/orders")]
    public class OrdersController : ApiController
    {
        private readonly IOrderService _orderService;

        public OrdersController(IOrderService orderService)
        {
            _orderService = orderService;
        }

        [HttpGet]
        [Route("")]
        public async Task<IHttpActionResult> GetAll()
        {
            var orders = await _orderService.GetAllOrdersAsync();
            return Ok(orders);
        }

        [HttpGet]
        [Route("{id:int}")]
        public async Task<IHttpActionResult> GetById(int id)
        {
            var order = await _orderService.GetOrderByIdAsync(id);
            if (order == null) return NotFound();
            return Ok(order);
        }

        /// <summary>
        /// Tạo đơn hàng mới. Logic:
        /// 1. Check Stock → 2. Create Order → 3. Update Product Stock
        /// Tất cả nằm trong Database Transaction.
        /// </summary>
        [HttpPost]
        [Route("")]
        public async Task<IHttpActionResult> Create([FromBody] CreateOrderDto dto)
        {
            // userId could come from JWT claims in a real auth scenario
            var userId = User.Identity?.IsAuthenticated == true
                ? User.Identity.Name
                : null;

            var order = await _orderService.CreateOrderAsync(dto, userId);
            return CreatedAtRoute("DefaultApi", new { id = order.Id }, order);
        }

        [HttpPatch]
        [Route("{id:int}/status")]
        public async Task<IHttpActionResult> UpdateStatus(int id, [FromBody] int status)
        {
            var result = await _orderService.UpdateOrderStatusAsync(id, status);
            if (!result) return NotFound();
            return StatusCode(System.Net.HttpStatusCode.NoContent);
        }

        [HttpGet]
        [Route("by-date")]
        public async Task<IHttpActionResult> GetByDateRange(DateTime from, DateTime to)
        {
            var orders = await _orderService.GetOrdersByDateRangeAsync(from, to);
            return Ok(orders);
        }
    }
}
