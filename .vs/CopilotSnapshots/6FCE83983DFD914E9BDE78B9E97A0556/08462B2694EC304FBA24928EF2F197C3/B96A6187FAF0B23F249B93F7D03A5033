/* ============================================================
   DesktopShop Admin Theme
   Inspired by phongvu.vn — modern, clean, professional
   ============================================================ */

/* ---------- Variables ---------- */
:root {
    --primary: #1a73e8;
    --primary-dark: #1557b0;
    --primary-light: #e8f0fe;
    --success: #0d9f6e;
    --danger: #e02424;
    --warning: #f59e0b;
    --info: #3b82f6;
    --dark: #1f2937;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-300: #d1d5db;
    --gray-400: #9ca3af;
    --gray-500: #6b7280;
    --gray-600: #4b5563;
    --gray-700: #374151;
    --gray-800: #1f2937;
    --sidebar-w: 260px;
    --topbar-h: 60px;
    --radius: 12px;
    --shadow-sm: 0 1px 3px rgba(0,0,0,.08);
    --shadow-md: 0 4px 12px rgba(0,0,0,.1);
    --shadow-lg: 0 8px 30px rgba(0,0,0,.12);
    --transition: all .25s cubic-bezier(.4,0,.2,1);
}

/* ---------- Base ---------- */
*, *::before, *::after { box-sizing: border-box; }

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--gray-100);
    color: var(--gray-800);
    margin: 0;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
}

/* ---------- Sidebar ---------- */
.sidebar {
    position: fixed;
    top: 0; left: 0;
    width: var(--sidebar-w);
    height: 100vh;
    background: var(--dark);
    color: #fff;
    display: flex;
    flex-direction: column;
    z-index: 1040;
    transition: var(--transition);
}

.sidebar-brand {
    height: var(--topbar-h);
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 20px;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -.5px;
    border-bottom: 1px solid rgba(255,255,255,.08);
    flex-shrink: 0;
}

.sidebar-brand i {
    font-size: 1.4rem;
    color: var(--primary);
}

.sidebar-nav {
    flex: 1;
    padding: 12px 10px;
    overflow-y: auto;
}

.sidebar-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 16px;
    border-radius: 8px;
    color: var(--gray-300);
    text-decoration: none;
    font-size: .9rem;
    font-weight: 500;
    transition: var(--transition);
    margin-bottom: 2px;
}

.sidebar-link:hover {
    background: rgba(255,255,255,.08);
    color: #fff;
}

.sidebar-link.active {
    background: var(--primary);
    color: #fff;
    box-shadow: 0 2px 8px rgba(26,115,232,.4);
}

.sidebar-link i {
    width: 20px;
    text-align: center;
    font-size: 1rem;
}

.sidebar-footer {
    padding: 10px;
    border-top: 1px solid rgba(255,255,255,.08);
}

/* ---------- Topbar ---------- */
.main-wrapper {
    margin-left: var(--sidebar-w);
    transition: var(--transition);
}

.topbar {
    position: sticky;
    top: 0;
    height: var(--topbar-h);
    background: #fff;
    border-bottom: 1px solid var(--gray-200);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    z-index: 1030;
}

.sidebar-toggle {
    font-size: 1.2rem;
    color: var(--gray-600);
    border: none;
    padding: 6px 10px;
    border-radius: 8px;
    transition: var(--transition);
}

.sidebar-toggle:hover { background: var(--gray-100); color: var(--gray-800); }

.topbar-right {
    display: flex;
    align-items: center;
    gap: 20px;
}

.topbar-clock {
    font-size: .85rem;
    color: var(--gray-500);
    font-weight: 500;
}

.topbar-user {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: .9rem;
    color: var(--gray-700);
}

.topbar-user i { font-size: 1.5rem; color: var(--primary); }

/* ---------- Page Content ---------- */
.page-content {
    padding: 24px;
    min-height: calc(100vh - var(--topbar-h));
}

.page-header {
    position: sticky;
    top: var(--topbar-h);
    z-index: 1020;
    background: var(--gray-100);
    margin: -24px -24px 24px -24px;
    padding: 24px 24px 0 24px;
}

.page-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gray-800);
    margin: 0;
}

.page-header p {
    color: var(--gray-500);
    font-size: .875rem;
    margin: 4px 0 0;
}

/* ---------- Stat Cards ---------- */
.stat-card {
    background: #fff;
    border-radius: var(--radius);
    padding: 20px 24px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--gray-200);
    display: flex;
    align-items: center;
    gap: 16px;
    transition: var(--transition);
}

.stat-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.stat-icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    flex-shrink: 0;
}

.stat-icon.blue   { background: #dbeafe; color: #2563eb; }
.stat-icon.green  { background: #d1fae5; color: #059669; }
.stat-icon.orange { background: #ffedd5; color: #ea580c; }
.stat-icon.purple { background: #ede9fe; color: #7c3aed; }

.stat-info h3 {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0;
    line-height: 1.2;
}

.stat-info p {
    font-size: .8rem;
    color: var(--gray-500);
    margin: 4px 0 0;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: .5px;
}

/* ---------- Cards / Panels ---------- */
.card-panel {
    background: #fff;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--gray-200);
    overflow: hidden;
}

.card-panel-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--gray-200);
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.card-panel-header h5 {
    margin: 0;
    font-size: .95rem;
    font-weight: 700;
    color: var(--gray-800);
}

.card-panel-body {
    padding: 20px;
}

/* ---------- Tables ---------- */
.table-modern {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: .875rem;
}

.table-modern thead th {
    background: var(--gray-50);
    color: var(--gray-500);
    font-weight: 600;
    text-transform: uppercase;
    font-size: .75rem;
    letter-spacing: .5px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--gray-200);
    position: sticky;
    top: 0;
    z-index: 2;
}

.table-scroll-container {
    max-height: 520px;
    overflow-y: auto;
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
}

.table-modern tbody td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--gray-100);
    vertical-align: middle;
}

.table-modern tbody tr:hover { background: var(--gray-50); }

/* ---------- Badges ---------- */
.badge-status {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: .75rem;
    font-weight: 600;
    display: inline-block;
}

.badge-pending   { background: #fef3c7; color: #92400e; }
.badge-confirmed { background: #dbeafe; color: #1e40af; }
.badge-completed { background: #d1fae5; color: #065f46; }
.badge-cancelled { background: #fee2e2; color: #991b1b; }

/* ---------- Product Cards (POS) ---------- */
.product-card {
    background: #fff;
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: var(--transition);
    height: 100%;
    display: flex;
    flex-direction: column;
}

.product-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: var(--primary);
}

.product-card-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    background: var(--gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.product-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.product-card-img .placeholder-icon {
    font-size: 3rem;
    color: var(--gray-300);
}

.product-card-body {
    padding: 14px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
}

.product-card-body .product-name {
    font-size: .9rem;
    font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 8px;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.product-specs {
    font-size: .78rem;
    color: var(--gray-500);
    margin-bottom: 10px;
    line-height: 1.6;
}

.product-specs i { width: 14px; color: var(--gray-400); margin-right: 4px; }

.product-card-footer {
    padding: 0 16px 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
}

.product-price {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--danger);
}

.product-stock {
    font-size: .75rem;
    color: var(--gray-400);
}

.product-stock.low { color: var(--warning); }
.product-stock.out { color: var(--danger); }

/* ---------- Buttons ---------- */
.btn-add-cart {
    background: var(--primary);
    color: #fff;
    border: none;
    padding: 8px 14px;
    border-radius: 8px;
    font-size: .8rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
}

.btn-add-cart:hover {
    background: var(--primary-dark);
    transform: scale(1.04);
    box-shadow: 0 2px 8px rgba(26,115,232,.3);
}

.btn-add-cart:disabled {
    background: var(--gray-300);
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

.btn-primary-modern {
    background: var(--primary);
    color: #fff;
    border: none;
    padding: 10px 20px;
    border-radius: 8px;
    font-size: .875rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
}

.btn-primary-modern:hover {
    background: var(--primary-dark);
    box-shadow: 0 4px 14px rgba(26,115,232,.3);
    color: #fff;
}

.btn-success-modern {
    background: var(--success);
    color: #fff;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: .95rem;
    font-weight: 700;
    cursor: pointer;
    transition: var(--transition);
    width: 100%;
}

.btn-success-modern:hover {
    background: #0b8a5e;
    box-shadow: 0 4px 14px rgba(13,159,110,.3);
    color: #fff;
    transform: translateY(-1px);
}

.btn-success-modern:disabled {
    background: var(--gray-300);
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

.btn-outline-modern {
    background: transparent;
    color: var(--gray-600);
    border: 1px solid var(--gray-300);
    padding: 8px 16px;
    border-radius: 8px;
    font-size: .8rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
}

.btn-outline-modern:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: var(--primary-light);
}

.btn-outline-modern.active {
    background: var(--primary);
    color: #fff;
    border-color: var(--primary);
}

/* ---------- Cart Sidebar (POS) ---------- */
.cart-sidebar {
    background: #fff;
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: calc(var(--topbar-h) + 24px);
    display: flex;
    flex-direction: column;
    max-height: calc(100vh - var(--topbar-h) - 48px);
}

.cart-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--gray-200);
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.cart-header h5 {
    margin: 0;
    font-weight: 700;
    font-size: .95rem;
}

.cart-badge {
    background: var(--primary);
    color: #fff;
    border-radius: 20px;
    padding: 2px 10px;
    font-size: .75rem;
    font-weight: 700;
}

.cart-body {
    flex: 1;
    overflow-y: auto;
    padding: 12px 16px;
}

.cart-empty {
    text-align: center;
    padding: 40px 20px;
    color: var(--gray-400);
}

.cart-empty i {
    font-size: 2.5rem;
    margin-bottom: 12px;
    display: block;
}

.cart-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--gray-100);
}

.cart-item:last-child { border-bottom: none; }

.cart-item-info {
    flex: 1;
    min-width: 0;
}

.cart-item-name {
    font-size: .82rem;
    font-weight: 600;
    color: var(--gray-800);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.cart-item-price {
    font-size: .78rem;
    color: var(--danger);
    font-weight: 600;
}

.cart-item-qty {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
}

.cart-item-qty button {
    width: 26px;
    height: 26px;
    border: 1px solid var(--gray-300);
    border-radius: 6px;
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .7rem;
    transition: var(--transition);
}

.cart-item-qty button:hover { border-color: var(--primary); color: var(--primary); }

.cart-item-qty span {
    font-size: .82rem;
    font-weight: 600;
    min-width: 24px;
    text-align: center;
}

.cart-item-remove {
    color: var(--gray-400);
    cursor: pointer;
    font-size: .85rem;
    padding: 4px;
    transition: var(--transition);
    flex-shrink: 0;
    margin-top: 2px;
}

.cart-item-remove:hover { color: var(--danger); }

.cart-footer {
    padding: 16px 20px;
    border-top: 1px solid var(--gray-200);
}

.cart-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
}

.cart-total-label {
    font-size: .9rem;
    font-weight: 600;
    color: var(--gray-600);
}

.cart-total-value {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--danger);
}

/* ---------- Search & Filter Bar ---------- */
.filter-bar {
    background: #fff;
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    padding: 16px 20px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    position: sticky;
    top: calc(var(--topbar-h) + 80px);
    z-index: 1019;
}

.search-input-wrapper {
    position: relative;
    flex: 1;
    min-width: 200px;
}

.search-input-wrapper i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gray-400);
    font-size: .85rem;
}

.search-input {
    width: 100%;
    padding: 10px 14px 10px 40px;
    border: 1px solid var(--gray-300);
    border-radius: 8px;
    font-size: .875rem;
    font-family: 'Inter', sans-serif;
    transition: var(--transition);
    max-width: none;
}

.search-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(26,115,232,.15);
}

.filter-buttons {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
}

/* ---------- Customer Form (modal) ---------- */
.form-floating-modern label {
    font-size: .8rem;
    font-weight: 600;
    color: var(--gray-600);
    margin-bottom: 4px;
}

.form-floating-modern input,
.form-floating-modern textarea {
    border: 1px solid var(--gray-300);
    border-radius: 8px;
    padding: 10px 14px;
    font-family: 'Inter', sans-serif;
    font-size: .875rem;
    width: 100%;
    max-width: none;
    transition: var(--transition);
}

.form-floating-modern input:focus,
.form-floating-modern textarea:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(26,115,232,.15);
    outline: none;
}

/* ---------- Chart containers ---------- */
.chart-container {
    position: relative;
    width: 100%;
}

/* ---------- Scrollbar ---------- */
.cart-body::-webkit-scrollbar,
.sidebar-nav::-webkit-scrollbar {
    width: 4px;
}

.cart-body::-webkit-scrollbar-thumb,
.sidebar-nav::-webkit-scrollbar-thumb {
    background: var(--gray-300);
    border-radius: 4px;
}

/* ---------- Responsive ---------- */
@media (max-width: 991.98px) {
    .sidebar {
        transform: translateX(-100%);
    }

    .sidebar.open {
        transform: translateX(0);
    }

    .main-wrapper {
        margin-left: 0;
    }

    .cart-sidebar {
        position: static;
        max-height: none;
    }
}

@media (max-width: 767.98px) {
    .page-content { padding: 16px; }
    .stat-card { padding: 16px; }
    .page-header {
        margin: -16px -16px 16px -16px;
        padding: 16px 16px 0 16px;
    }
    .filter-bar { flex-direction: column; align-items: stretch; }
    .search-input-wrapper { min-width: auto; }
}

/* ---------- Loading spinner ---------- */
.spinner-overlay {
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border-radius: var(--radius);
}

/* ---------- Animation ---------- */
@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
}

.animate-in {
    animation: fadeInUp .4s ease both;
}

.animate-in:nth-child(1) { animation-delay: .05s; }
.animate-in:nth-child(2) { animation-delay: .1s;  }
.animate-in:nth-child(3) { animation-delay: .15s; }
.animate-in:nth-child(4) { animation-delay: .2s;  }

/* ---------- Modal form controls ---------- */
#productModal .form-control,
#productModal .form-select {
    border: 1px solid var(--gray-300);
    border-radius: 8px;
    padding: 10px 14px;
    font-family: 'Inter', sans-serif;
    font-size: .875rem;
    transition: var(--transition);
    max-width: none;
}

#productModal .form-control:focus,
#productModal .form-select:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(26,115,232,.15);
    outline: none;
}

#productModal .form-label {
    color: var(--gray-600);
}

#productModal .modal-backdrop { backdrop-filter: blur(2px); }
