@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h1><i class="fa-solid fa-computer me-2"></i>Quản lý Sản Phẩm</h1>
        <p>Danh sách tất cả Desktop Computer trong kho hàng</p>
    </div>
    <button class="btn btn-primary-modern" id="btnAddProduct">
        <i class="fa-solid fa-plus me-1"></i>Thêm sản phẩm
    </button>
</div>

<!-- Filter -->
<div class="filter-bar mb-3">
    <div class="search-input-wrapper">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="productSearch" class="search-input" placeholder="Tìm kiếm sản phẩm..." />
    </div>
    <select id="categorySelect" class="form-select" style="width:auto;border-radius:8px;font-size:.875rem;font-family:'Inter',sans-serif;">
        <option value="0">Tất cả danh mục</option>
    </select>
</div>

<!-- Product Table -->
<div class="card-panel">
    <div class="card-panel-body p-0">
        <table class="table-modern">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th>CPU</th>
                    <th>RAM</th>
                    <th class="text-end">Giá</th>
                    <th class="text-center">Kho</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody id="productsTableBody">
                <tr><td colspan="10" class="text-center py-4 text-muted">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section scripts {
    <script>
        $(function () {
            var API = '/api';
            var products = [];
            var categories = [];

            function loadAll() {
                $.when(
                    $.getJSON(API + '/products'),
                    $.getJSON(API + '/categories')
                ).done(function (pRes, cRes) {
                    products = Array.isArray(pRes[0]) ? pRes[0] : (pRes[0].data || []);
                    categories = Array.isArray(cRes[0]) ? cRes[0] : (cRes[0].data || []);
                    renderCategorySelect();
                    renderTable();
                ).fail(function (jqXHR, textStatus, errorThrown) {
                    console.error('Load products failed:', textStatus, errorThrown, jqXHR.responseText);
                    $('#productsTableBody').html('<tr><td colspan="10" class="text-center py-4 text-danger">Không thể tải dữ liệu</td></tr>');
                });
            }

            function renderCategorySelect() {
                var $sel = $('#categorySelect');
                categories.forEach(function (c) {
                    $sel.append('<option value="' + (c.Id || c.id) + '">' + (c.Name || c.name) + '</option>');
                });
            }

            function renderTable() {
                var keyword = $.trim($('#productSearch').val()).toLowerCase();
                var catId = parseInt($('#categorySelect').val()) || 0;

                var filtered = products.filter(function (p) {
                    var matchCat = catId === 0 || (p.CategoryId || p.categoryId) === catId;
                    var matchSearch = !keyword || (p.Name || p.name || '').toLowerCase().indexOf(keyword) >= 0;
                    return matchCat && matchSearch;
                });

                if (!filtered.length) {
                    $('#productsTableBody').html('<tr><td colspan="10" class="text-center py-4 text-muted">Không tìm thấy sản phẩm</td></tr>');
                    return;
                }

                var html = '';
                filtered.forEach(function (p) {
                    var stock = p.StockQuantity != null ? p.StockQuantity : p.stockQuantity;
                    var minStock = p.MinStockLevel != null ? p.MinStockLevel : (p.minStockLevel || 3);
                    var stockClass = stock <= 0 ? 'text-danger fw-bold' : (stock <= minStock ? 'text-warning fw-bold' : '');
                    var imgUrl = p.ImageUrl || p.imageUrl;

                    html += '<tr>' +
                        '<td class="text-muted">#' + (p.Id || p.id) + '</td>' +
                        '<td>' + (imgUrl ? '<img src="' + imgUrl + '" style="width:40px;height:40px;border-radius:6px;object-fit:cover" />' : '<i class="fa-solid fa-image text-muted"></i>') + '</td>' +
                        '<td class="fw-semibold">' + (p.Name || p.name) + '</td>' +
                        '<td>' + (p.CategoryName || p.categoryName || '') + '</td>' +
                        '<td class="text-muted">' + (p.CPU || p.cpu || '-') + '</td>' +
                        '<td class="text-muted">' + (p.RAM || p.ram || '-') + '</td>' +
                        '<td class="text-end text-danger fw-bold">' + formatVND(p.Price || p.price) + '</td>' +
                        '<td class="text-center ' + stockClass + '">' + stock + '</td>' +
                        '<td>' + (p.IsActive !== false && p.isActive !== false ? '<span class="badge-status badge-completed">Hoạt động</span>' : '<span class="badge-status badge-cancelled">Ẩn</span>') + '</td>' +
                        '<td class="text-center">' +
                            '<button class="btn btn-sm btn-outline-modern me-1" title="Sửa"><i class="fa-solid fa-pen"></i></button>' +
                            '<button class="btn btn-sm btn-outline-modern text-danger" title="Xóa"><i class="fa-solid fa-trash"></i></button>' +
                        '</td>' +
                        '</tr>';
                });
                $('#productsTableBody').html(html);
            }

            $('#productSearch').on('input', function () { renderTable(); });
            $('#categorySelect').on('change', function () { renderTable(); });

            loadAll();
        });
    </script>
}
