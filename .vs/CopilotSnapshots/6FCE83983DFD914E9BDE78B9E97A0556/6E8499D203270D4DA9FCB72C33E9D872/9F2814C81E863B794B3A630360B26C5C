@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h1><i class="fa-solid fa-chart-line me-2"></i>Xem Doanh Thu</h1>
    <p>Tra cứu doanh thu theo ngày, tháng, năm hoặc khoảng thời gian</p>
</div>

<!-- Tab Navigation -->
<ul class="nav nav-tabs mb-4" id="revenueTabs" role="tablist" style="border-bottom:2px solid var(--gray-200)">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-semibold" id="tab-single" data-bs-toggle="tab" data-bs-target="#paneSingle"
                type="button" role="tab" style="border-radius:8px 8px 0 0;font-size:.9rem">
            <i class="fa-solid fa-calendar-day me-1"></i>Theo ngày cụ thể
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-semibold" id="tab-range" data-bs-toggle="tab" data-bs-target="#paneRange"
                type="button" role="tab" style="border-radius:8px 8px 0 0;font-size:.9rem">
            <i class="fa-solid fa-calendar-range me-1"></i>Từ ngày – Đến ngày
        </button>
    </li>
</ul>

<div class="tab-content" id="revenueTabContent">

<!-- ==================== TAB 1: SINGLE DATE ==================== -->
<div class="tab-pane fade show active" id="paneSingle" role="tabpanel">

<!-- Date Picker -->
<div class="card-panel mb-4">
    <div class="card-panel-body">
        <div class="row align-items-end g-3">
            <div class="col-md-4">
                <label class="form-label fw-semibold" style="font-size:.85rem">
                    <i class="fa-solid fa-calendar-day me-1"></i>Chọn ngày
                </label>
                <input type="date" class="form-control" id="revenueDate"
                       style="border-radius:8px;font-family:'Inter',sans-serif;" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary-modern w-100" id="btnLookup">
                    <i class="fa-solid fa-magnifying-glass-chart me-1"></i>Xem doanh thu
                </button>
            </div>
            <div class="col-md-5 text-end">
                <span id="selectedDateLabel" class="text-muted" style="font-size:.85rem"></span>
            </div>
        </div>
    </div>
</div>

<!-- Revenue Cards -->
<div id="revenueResult" style="display:none">
    <div class="row g-3 mb-4">
        <!-- Day Revenue -->
        <div class="col-lg-4 col-md-6 animate-in">
            <div class="card-panel h-100" style="border-left:4px solid var(--primary)">
                <div class="card-panel-body text-center py-4">
                    <div class="stat-icon blue mx-auto mb-3" style="width:56px;height:56px;font-size:1.4rem">
                        <i class="fa-solid fa-calendar-day"></i>
                    </div>
                    <p class="text-muted mb-1" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px">
                        Doanh thu ngày
                    </p>
                    <h6 class="fw-bold text-muted mb-2" id="dayLabel" style="font-size:.85rem">--</h6>
                    <h2 class="fw-bold mb-2" style="color:var(--primary)" id="dayRevenue">--</h2>
                    <div class="d-flex justify-content-center gap-3" style="font-size:.82rem">
                        <span class="text-muted">
                            <i class="fa-solid fa-receipt me-1"></i><span id="dayOrders">0</span> đơn hoàn thành
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Month Revenue -->
        <div class="col-lg-4 col-md-6 animate-in">
            <div class="card-panel h-100" style="border-left:4px solid var(--success)">
                <div class="card-panel-body text-center py-4">
                    <div class="stat-icon green mx-auto mb-3" style="width:56px;height:56px;font-size:1.4rem">
                        <i class="fa-solid fa-calendar-week"></i>
                    </div>
                    <p class="text-muted mb-1" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px">
                        Doanh thu tháng
                    </p>
                    <h6 class="fw-bold text-muted mb-2" id="monthLabel" style="font-size:.85rem">--</h6>
                    <h2 class="fw-bold mb-2" style="color:var(--success)" id="monthRevenue">--</h2>
                    <div class="d-flex justify-content-center gap-3" style="font-size:.82rem">
                        <span class="text-muted">
                            <i class="fa-solid fa-receipt me-1"></i><span id="monthOrders">0</span> đơn hoàn thành
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Year Revenue -->
        <div class="col-lg-4 col-md-6 animate-in">
            <div class="card-panel h-100" style="border-left:4px solid var(--warning)">
                <div class="card-panel-body text-center py-4">
                    <div class="stat-icon orange mx-auto mb-3" style="width:56px;height:56px;font-size:1.4rem">
                        <i class="fa-solid fa-calendar"></i>
                    </div>
                    <p class="text-muted mb-1" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px">
                        Doanh thu năm
                    </p>
                    <h6 class="fw-bold text-muted mb-2" id="yearLabel" style="font-size:.85rem">--</h6>
                    <h2 class="fw-bold mb-2" style="color:var(--warning)" id="yearRevenue">--</h2>
                    <div class="d-flex justify-content-center gap-3" style="font-size:.82rem">
                        <span class="text-muted">
                            <i class="fa-solid fa-receipt me-1"></i><span id="yearOrders">0</span> đơn hoàn thành
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Comparison Bar -->
    <div class="card-panel">
        <div class="card-panel-header">
            <h5><i class="fa-solid fa-chart-bar me-2"></i>So sánh doanh thu</h5>
        </div>
        <div class="card-panel-body">
            <div class="chart-container" style="height:300px">
                <canvas id="revenueCompareChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Empty State -->
<div id="revenueEmpty" class="text-center py-5">
    <i class="fa-solid fa-calendar-check fa-3x text-muted mb-3 d-block" style="opacity:.4"></i>
    <h5 class="text-muted">Chọn ngày để xem doanh thu</h5>
    <p class="text-muted" style="font-size:.85rem">Chọn một ngày cụ thể ở trên rồi nhấn "Xem doanh thu"</p>
</div>

</div><!-- end #paneSingle -->

<!-- ==================== TAB 2: DATE RANGE ==================== -->
<div class="tab-pane fade" id="paneRange" role="tabpanel">

<!-- Range Date Picker -->
<div class="card-panel mb-4">
    <div class="card-panel-body">
        <div class="row align-items-end g-3">
            <div class="col-md-3">
                <label class="form-label fw-semibold" style="font-size:.85rem">
                    <i class="fa-solid fa-calendar-arrow-down me-1"></i>Từ ngày
                </label>
                <input type="date" class="form-control" id="rangeFrom"
                       style="border-radius:8px;font-family:'Inter',sans-serif;" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold" style="font-size:.85rem">
                    <i class="fa-solid fa-calendar-arrow-up me-1"></i>Đến ngày
                </label>
                <input type="date" class="form-control" id="rangeTo"
                       style="border-radius:8px;font-family:'Inter',sans-serif;" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary-modern w-100" id="btnRangeLookup">
                    <i class="fa-solid fa-magnifying-glass-chart me-1"></i>Xem doanh thu
                </button>
            </div>
            <div class="col-md-3 text-end">
                <span id="rangeDateLabel" class="text-muted" style="font-size:.85rem"></span>
            </div>
        </div>
        <!-- Quick select buttons -->
        <div class="mt-3 d-flex flex-wrap gap-2">
            <span class="text-muted me-1" style="font-size:.82rem;line-height:30px">Nhanh:</span>
            <button class="btn btn-sm btn-outline-modern btn-quick-range" data-days="7">7 ngày</button>
            <button class="btn btn-sm btn-outline-modern btn-quick-range" data-days="14">14 ngày</button>
            <button class="btn btn-sm btn-outline-modern btn-quick-range" data-days="30">30 ngày</button>
            <button class="btn btn-sm btn-outline-modern btn-quick-range" data-days="90">90 ngày</button>
            <button class="btn btn-sm btn-outline-modern" id="btnThisMonth">Tháng này</button>
            <button class="btn btn-sm btn-outline-modern" id="btnThisYear">Năm này</button>
        </div>
    </div>
</div>

<!-- Range Result -->
<div id="rangeResult" style="display:none">
    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-lg-4 col-md-6 animate-in">
            <div class="card-panel h-100" style="border-left:4px solid var(--primary)">
                <div class="card-panel-body text-center py-4">
                    <div class="stat-icon blue mx-auto mb-3" style="width:56px;height:56px;font-size:1.4rem">
                        <i class="fa-solid fa-sack-dollar"></i>
                    </div>
                    <p class="text-muted mb-1" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px">
                        Tổng doanh thu
                    </p>
                    <h6 class="fw-bold text-muted mb-2" id="rangePeriodLabel" style="font-size:.82rem">--</h6>
                    <h2 class="fw-bold mb-2" style="color:var(--primary)" id="rangeTotalRevenue">--</h2>
                    <div style="font-size:.82rem" class="text-muted">
                        <i class="fa-solid fa-receipt me-1"></i><span id="rangeTotalOrders">0</span> đơn hoàn thành
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 animate-in">
            <div class="card-panel h-100" style="border-left:4px solid var(--success)">
                <div class="card-panel-body text-center py-4">
                    <div class="stat-icon green mx-auto mb-3" style="width:56px;height:56px;font-size:1.4rem">
                        <i class="fa-solid fa-chart-simple"></i>
                    </div>
                    <p class="text-muted mb-1" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px">
                        Trung bình / ngày
                    </p>
                    <h6 class="fw-bold text-muted mb-2" id="rangeDaysCount" style="font-size:.82rem">-- ngày</h6>
                    <h2 class="fw-bold mb-2" style="color:var(--success)" id="rangeAvgRevenue">--</h2>
                    <div style="font-size:.82rem" class="text-muted">
                        <i class="fa-solid fa-calculator me-1"></i>Doanh thu TB mỗi ngày
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 animate-in">
            <div class="card-panel h-100" style="border-left:4px solid var(--warning)">
                <div class="card-panel-body text-center py-4">
                    <div class="stat-icon orange mx-auto mb-3" style="width:56px;height:56px;font-size:1.4rem">
                        <i class="fa-solid fa-arrow-up-right-dots"></i>
                    </div>
                    <p class="text-muted mb-1" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px">
                        Ngày cao nhất
                    </p>
                    <h6 class="fw-bold text-muted mb-2" id="rangePeakDay" style="font-size:.82rem">--</h6>
                    <h2 class="fw-bold mb-2" style="color:var(--warning)" id="rangePeakRevenue">--</h2>
                    <div style="font-size:.82rem" class="text-muted">
                        <i class="fa-solid fa-crown me-1"></i>Doanh thu cao nhất
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Daily Chart -->
    <div class="card-panel mb-4">
        <div class="card-panel-header">
            <h5><i class="fa-solid fa-chart-area me-2"></i>Doanh thu theo ngày</h5>
        </div>
        <div class="card-panel-body">
            <div class="chart-container" style="height:350px">
                <canvas id="rangeDailyChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Daily Table -->
    <div class="card-panel">
        <div class="card-panel-header">
            <h5><i class="fa-solid fa-table me-2"></i>Chi tiết doanh thu từng ngày</h5>
        </div>
        <div class="card-panel-body p-0">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Ngày</th>
                        <th class="text-end">Doanh thu</th>
                        <th class="text-center">Số đơn</th>
                        <th>Tỷ lệ</th>
                    </tr>
                </thead>
                <tbody id="rangeDailyTable">
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Range Empty State -->
<div id="rangeEmpty" class="text-center py-5">
    <i class="fa-solid fa-calendar-week fa-3x text-muted mb-3 d-block" style="opacity:.4"></i>
    <h5 class="text-muted">Chọn khoảng thời gian</h5>
    <p class="text-muted" style="font-size:.85rem">Chọn ngày bắt đầu và kết thúc, hoặc dùng nút chọn nhanh bên trên</p>
</div>

</div><!-- end #paneRange -->
</div><!-- end .tab-content -->

@section scripts {
    <script>
        $(function () {
            var compareChart = null;
            var rangeDailyChart = null;

            // Helper: format date to yyyy-MM-dd for input
            function toInputDate(d) {
                var yyyy = d.getFullYear();
                var mm = String(d.getMonth() + 1).padStart(2, '0');
                var dd = String(d.getDate()).padStart(2, '0');
                return yyyy + '-' + mm + '-' + dd;
            }

            var today = new Date();
            $('#revenueDate').val(toInputDate(today));

            // Default range: last 30 days
            var rangeDef = new Date();
            rangeDef.setDate(rangeDef.getDate() - 30);
            $('#rangeFrom').val(toInputDate(rangeDef));
            $('#rangeTo').val(toInputDate(today));

            // ==================== TAB 1: SINGLE DATE ====================
            $('#btnLookup').on('click', function () {
                var dateVal = $('#revenueDate').val();
                if (!dateVal) {
                    showToast('warning', 'Vui lòng chọn ngày!');
                    return;
                }
                loadRevenue(dateVal);
            });

            $('#revenueDate').on('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    $('#btnLookup').click();
                }
            });

            function loadRevenue(dateStr) {
                var $btn = $('#btnLookup');
                $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-1"></i>Đang tải...');

                $.getJSON('/api/dashboard/revenue-by-date?date=' + encodeURIComponent(dateStr))
                    .done(function (data) {
                        renderRevenue(data);
                    })
                    .fail(function () {
                        showToast('error', 'Không thể tải dữ liệu doanh thu!');
                    })
                    .always(function () {
                        $btn.prop('disabled', false).html('<i class="fa-solid fa-magnifying-glass-chart me-1"></i>Xem doanh thu');
                    });
            }

            function renderRevenue(data) {
                var dayRev = data.dayRevenue || data.DayRevenue || 0;
                var monthRev = data.monthRevenue || data.MonthRevenue || 0;
                var yearRev = data.yearRevenue || data.YearRevenue || 0;
                var dayCount = data.dayOrderCount || data.DayOrderCount || 0;
                var monthCount = data.monthOrderCount || data.MonthOrderCount || 0;
                var yearCount = data.yearOrderCount || data.YearOrderCount || 0;
                var selectedDate = data.selectedDate || data.SelectedDate || '';
                var monthLbl = data.monthLabel || data.MonthLabel || '';
                var yearLbl = data.yearLabel || data.YearLabel || '';

                $('#dayLabel').text(selectedDate);
                $('#dayRevenue').text(formatVND(dayRev));
                $('#dayOrders').text(dayCount);

                $('#monthLabel').text(monthLbl);
                $('#monthRevenue').text(formatVND(monthRev));
                $('#monthOrders').text(monthCount);

                $('#yearLabel').text(yearLbl);
                $('#yearRevenue').text(formatVND(yearRev));
                $('#yearOrders').text(yearCount);

                $('#selectedDateLabel').html(
                    '<i class="fa-solid fa-circle-check text-success me-1"></i>Đang xem doanh thu ngày <strong>' + selectedDate + '</strong>'
                );

                $('#revenueEmpty').hide();
                $('#revenueResult').fadeIn(300);

                renderCompareChart(
                    [selectedDate, monthLbl, yearLbl],
                    [dayRev, monthRev, yearRev],
                    [dayCount, monthCount, yearCount]
                );
            }

            function renderCompareChart(labels, values, counts) {
                if (compareChart) compareChart.destroy();

                var ctx = document.getElementById('revenueCompareChart').getContext('2d');
                compareChart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Doanh thu (VNĐ)',
                            data: values,
                            backgroundColor: [
                                'rgba(26, 115, 232, 0.8)',
                                'rgba(13, 159, 110, 0.8)',
                                'rgba(245, 158, 11, 0.8)'
                            ],
                            borderColor: [
                                'rgba(26, 115, 232, 1)',
                                'rgba(13, 159, 110, 1)',
                                'rgba(245, 158, 11, 1)'
                            ],
                            borderWidth: 2,
                            borderRadius: 8,
                            barPercentage: 0.5
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        var val = ctx.parsed.y || 0;
                                        var orderCount = counts[ctx.dataIndex] || 0;
                                        return ' ' + formatVND(val) + ' (' + orderCount + ' đơn)';
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(0,0,0,.06)' },
                                ticks: {
                                    callback: function (val) {
                                        if (val >= 1000000000) return (val / 1000000000).toFixed(1) + ' tỷ';
                                        if (val >= 1000000) return (val / 1000000).toFixed(0) + ' tr';
                                        if (val >= 1000) return (val / 1000).toFixed(0) + 'k';
                                        return val;
                                    },
                                    font: { family: "'Inter', sans-serif", size: 11 }
                                }
                            },
                            x: {
                                grid: { display: false },
                                ticks: { font: { family: "'Inter', sans-serif", size: 12, weight: '600' } }
                            }
                        }
                    }
                });
            }

            // ==================== TAB 2: DATE RANGE ====================
            $('#btnRangeLookup').on('click', function () {
                var fromVal = $('#rangeFrom').val();
                var toVal = $('#rangeTo').val();
                if (!fromVal || !toVal) {
                    showToast('warning', 'Vui lòng chọn đầy đủ ngày bắt đầu và kết thúc!');
                    return;
                }
                if (fromVal > toVal) {
                    showToast('warning', 'Ngày bắt đầu phải nhỏ hơn hoặc bằng ngày kết thúc!');
                    return;
                }
                loadRangeRevenue(fromVal, toVal);
            });

            // Quick range buttons
            $('.btn-quick-range').on('click', function () {
                var days = parseInt($(this).data('days'));
                var to = new Date();
                var from = new Date();
                from.setDate(from.getDate() - days + 1);
                $('#rangeFrom').val(toInputDate(from));
                $('#rangeTo').val(toInputDate(to));
                loadRangeRevenue(toInputDate(from), toInputDate(to));
            });

            $('#btnThisMonth').on('click', function () {
                var now = new Date();
                var from = new Date(now.getFullYear(), now.getMonth(), 1);
                $('#rangeFrom').val(toInputDate(from));
                $('#rangeTo').val(toInputDate(now));
                loadRangeRevenue(toInputDate(from), toInputDate(now));
            });

            $('#btnThisYear').on('click', function () {
                var now = new Date();
                var from = new Date(now.getFullYear(), 0, 1);
                $('#rangeFrom').val(toInputDate(from));
                $('#rangeTo').val(toInputDate(now));
                loadRangeRevenue(toInputDate(from), toInputDate(now));
            });

            function loadRangeRevenue(fromStr, toStr) {
                var $btn = $('#btnRangeLookup');
                $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-1"></i>Đang tải...');

                $.getJSON('/api/dashboard/revenue-by-range?from=' + encodeURIComponent(fromStr) + '&to=' + encodeURIComponent(toStr))
                    .done(function (data) {
                        renderRangeRevenue(data);
                    })
                    .fail(function () {
                        showToast('error', 'Không thể tải dữ liệu doanh thu!');
                    })
                    .always(function () {
                        $btn.prop('disabled', false).html('<i class="fa-solid fa-magnifying-glass-chart me-1"></i>Xem doanh thu');
                    });
            }

            function renderRangeRevenue(data) {
                var totalRev = data.totalRevenue || data.TotalRevenue || 0;
                var totalOrders = data.totalOrderCount || data.TotalOrderCount || 0;
                var avgRev = data.averageDailyRevenue || data.AverageDailyRevenue || 0;
                var totalDays = data.totalDays || data.TotalDays || 0;
                var fromLbl = data.fromDate || data.FromDate || '';
                var toLbl = data.toDate || data.ToDate || '';
                var labels = data.dailyLabels || data.DailyLabels || [];
                var values = data.dailyValues || data.DailyValues || [];
                var orderCounts = data.dailyOrderCounts || data.DailyOrderCounts || [];

                // Find peak day
                var peakIdx = 0;
                var peakVal = 0;
                for (var i = 0; i < values.length; i++) {
                    if (values[i] > peakVal) {
                        peakVal = values[i];
                        peakIdx = i;
                    }
                }

                // Update cards
                $('#rangePeriodLabel').text(fromLbl + ' → ' + toLbl);
                $('#rangeTotalRevenue').text(formatVND(totalRev));
                $('#rangeTotalOrders').text(totalOrders);

                $('#rangeDaysCount').text(totalDays + ' ngày');
                $('#rangeAvgRevenue').text(formatVND(avgRev));

                $('#rangePeakDay').text(labels[peakIdx] || '--');
                $('#rangePeakRevenue').text(formatVND(peakVal));

                $('#rangeDateLabel').html(
                    '<i class="fa-solid fa-circle-check text-success me-1"></i>' + fromLbl + ' → ' + toLbl + ' (' + totalDays + ' ngày)'
                );

                // Render daily table
                var tableHtml = '';
                for (var i = 0; i < labels.length; i++) {
                    var pct = totalRev > 0 ? (values[i] / totalRev * 100) : 0;
                    var barWidth = Math.max(pct, 1);
                    var isPeak = (i === peakIdx && peakVal > 0);
                    tableHtml += '<tr' + (isPeak ? ' style="background:rgba(245,158,11,.06)"' : '') + '>' +
                        '<td class="fw-semibold">' + labels[i] + (isPeak ? ' <i class="fa-solid fa-crown text-warning" title="Cao nhất"></i>' : '') + '</td>' +
                        '<td class="text-end fw-bold" style="color:var(--primary)">' + formatVND(values[i]) + '</td>' +
                        '<td class="text-center">' + orderCounts[i] + '</td>' +
                        '<td style="width:30%">' +
                            '<div class="d-flex align-items-center gap-2">' +
                                '<div style="flex:1;height:8px;background:var(--gray-200);border-radius:4px;overflow:hidden">' +
                                    '<div style="width:' + barWidth.toFixed(1) + '%;height:100%;background:var(--primary);border-radius:4px;transition:width .3s"></div>' +
                                '</div>' +
                                '<span class="text-muted" style="font-size:.75rem;min-width:40px">' + pct.toFixed(1) + '%</span>' +
                            '</div>' +
                        '</td>' +
                        '</tr>';
                }
                $('#rangeDailyTable').html(tableHtml);

                // Render chart
                renderRangeDailyChart(labels, values, orderCounts);

                $('#rangeEmpty').hide();
                $('#rangeResult').fadeIn(300);
            }

            function renderRangeDailyChart(labels, values, orderCounts) {
                if (rangeDailyChart) rangeDailyChart.destroy();

                var ctx = document.getElementById('rangeDailyChart').getContext('2d');

                // Create gradient
                var gradient = ctx.createLinearGradient(0, 0, 0, 350);
                gradient.addColorStop(0, 'rgba(26, 115, 232, 0.3)');
                gradient.addColorStop(1, 'rgba(26, 115, 232, 0.02)');

                rangeDailyChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Doanh thu (VNĐ)',
                            data: values,
                            borderColor: 'rgba(26, 115, 232, 1)',
                            backgroundColor: gradient,
                            borderWidth: 2.5,
                            fill: true,
                            tension: 0.3,
                            pointRadius: labels.length <= 31 ? 4 : 0,
                            pointHoverRadius: 6,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: 'rgba(26, 115, 232, 1)',
                            pointBorderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: { intersect: false, mode: 'index' },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        var val = ctx.parsed.y || 0;
                                        var cnt = orderCounts[ctx.dataIndex] || 0;
                                        return ' ' + formatVND(val) + ' (' + cnt + ' đơn)';
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(0,0,0,.06)' },
                                ticks: {
                                    callback: function (val) {
                                        if (val >= 1000000000) return (val / 1000000000).toFixed(1) + ' tỷ';
                                        if (val >= 1000000) return (val / 1000000).toFixed(0) + ' tr';
                                        if (val >= 1000) return (val / 1000).toFixed(0) + 'k';
                                        return val;
                                    },
                                    font: { family: "'Inter', sans-serif", size: 11 }
                                }
                            },
                            x: {
                                grid: { display: false },
                                ticks: {
                                    maxRotation: 45,
                                    font: { family: "'Inter', sans-serif", size: 10 },
                                    autoSkip: true,
                                    maxTicksLimit: 15
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
}
