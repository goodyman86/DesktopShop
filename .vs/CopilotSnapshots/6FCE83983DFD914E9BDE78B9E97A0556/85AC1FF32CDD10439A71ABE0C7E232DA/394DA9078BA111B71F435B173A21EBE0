using System;
using System.IO;
using System.Net.Http;
using System.Threading.Tasks;
using DesktopShop.Application.Interfaces;
using SixLabors.ImageSharp;
using SixLabors.ImageSharp.Formats.Jpeg;
using SixLabors.ImageSharp.Formats.Png;
using SixLabors.ImageSharp.Processing;

namespace DesktopShop.Application.Services;

public class ImageService : IImageService
{
    private static readonly HttpClient _httpClient = new HttpClient
    {
        Timeout = TimeSpan.FromSeconds(30)
    };

    public async Task<string> DownloadResizeAndSaveAsync(
        string imageUrl, string saveFolderPath, int maxWidth = 800, int quality = 75)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
            throw new ArgumentException("Image URL khong duoc de trong.", nameof(imageUrl));

        Uri uri;
        if (!Uri.TryCreate(imageUrl, UriKind.Absolute, out uri) ||
            (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps))
        {
            throw new ArgumentException("URL khong hop le.", nameof(imageUrl));
        }

        byte[] imageBytes;
        string contentType;
        try
        {
            using (var request = new HttpRequestMessage(HttpMethod.Get, uri))
            {
                request.Headers.Add("User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64)");
                request.Headers.Add("Accept", "image/*");

                using (var response = await _httpClient.SendAsync(request))
                {
                    response.EnsureSuccessStatusCode();
                    contentType = response.Content.Headers.ContentType?.MediaType?.ToLowerInvariant() ?? string.Empty;
                    imageBytes = await response.Content.ReadAsByteArrayAsync();
                }
            }
        }
        catch (HttpRequestException ex)
        {
            throw new InvalidOperationException("Khong the tai anh tu URL: " + imageUrl, ex);
        }
        catch (TaskCanceledException ex)
        {
            throw new InvalidOperationException("Het thoi gian cho khi tai anh tu URL: " + imageUrl, ex);
        }

        if (imageBytes == null || imageBytes.Length == 0)
            throw new InvalidOperationException("Du lieu anh trong.");

        bool saveAsJpeg;
        switch (contentType)
        {
            case "image/jpeg":
            case "image/jpg":
                saveAsJpeg = true;
                break;
            case "image/png":
                saveAsJpeg = false;
                break;
            default:
                saveAsJpeg = true;
                break;
        }

        var fileName = Guid.NewGuid().ToString("N") + (saveAsJpeg ? ".jpg" : ".png");

        if (!Directory.Exists(saveFolderPath))
            Directory.CreateDirectory(saveFolderPath);

        var filePath = Path.Combine(saveFolderPath, fileName);

        using (var ms = new MemoryStream(imageBytes))
        using (var image = Image.Load(ms))
        {
            if (image.Width > maxWidth)
            {
                image.Mutate(ctx => ctx.Resize(new ResizeOptions
                {
                    Size = new Size(maxWidth, 0),
                    Mode = ResizeMode.Max
                }));
            }

            if (saveAsJpeg)
            {
                var encoder = new JpegEncoder { Quality = quality };
                image.Save(filePath, encoder);
            }
            else
            {
                var encoder = new PngEncoder
                {
                    CompressionLevel = PngCompressionLevel.BestCompression
                };
                image.Save(filePath, encoder);
            }
        }

        return fileName;
    }
}
