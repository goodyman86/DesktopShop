using System.Collections.Generic;
using System.Configuration;
using System.Data.SqlClient;
using System.Linq;
using System.Web.Mvc;
using DesktopShop.Domain.Entities;
using DesktopShop.Infrastructure.Data;
using DesktopShop.Infrastructure.Identity;
using Microsoft.EntityFrameworkCore;

namespace WebApplication1.Controllers
{
    public class CustomerAuthController : Controller
    {
        private ApplicationDbContext CreateDbContext()
        {
            var connectionString = ConfigurationManager.ConnectionStrings["DefaultConnection"].ConnectionString;
            var connection = new SqlConnection(connectionString);
            var optionsBuilder = new DbContextOptionsBuilder<ApplicationDbContext>();
            optionsBuilder.UseSqlServer(connection);
            return new ApplicationDbContext(optionsBuilder.Options);
        }

        public ActionResult Login()
        {
            if (Session["CustomerId"] != null)
                return RedirectToAction("Index", "Shop");

            ViewBag.Title = "Đăng nhập";
            return View();
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public ActionResult Login(string username, string password)
        {
            if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
            {
                ViewBag.Error = "Vui lòng nhập đầy đủ thông tin.";
                ViewBag.Title = "Đăng nhập";
                return View();
            }

            var hash = IdentitySeed.HashPassword(password);

            using (var context = CreateDbContext())
            {
                // All users login from Customers table
                var user = context.Customers
                    .FirstOrDefault(c => c.Username == username && c.PasswordHash == hash && c.IsActive);

                if (user != null)
                {
                    if (user.Role == "Admin")
                    {
                        // Admin → redirect to admin dashboard
                        Session["AdminId"] = user.Id;
                        Session["AdminName"] = user.FullName;
                        Session["AdminUsername"] = user.Username;
                        return RedirectToAction("Index", "DashboardView");
                    }

                    // Customer → redirect to shop
                    Session["CustomerId"] = user.Id;
                    Session["CustomerName"] = user.FullName;
                    Session["CustomerUsername"] = user.Username;

                    if (TempData["ReturnUrl"] is string returnUrl && !string.IsNullOrEmpty(returnUrl))
                        return Redirect(returnUrl);

                    return RedirectToAction("Index", "Shop");
                }
            }

            ViewBag.Error = "Tên đăng nhập hoặc mật khẩu không đúng.";
            ViewBag.Username = username;
            ViewBag.Title = "Đăng nhập";
            return View();
        }

        public ActionResult Register()
        {
            if (Session["CustomerId"] != null)
                return RedirectToAction("Index", "Shop");

            ViewBag.Title = "Đăng ký tài khoản";
            return View();
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public ActionResult Register(string username, string password, string confirmPassword,
            string fullName, string email, string phone, string address)
        {
            ViewBag.Title = "Đăng ký tài khoản";
            ViewBag.Username = username;
            ViewBag.FullName = fullName;
            ViewBag.Email = email;
            ViewBag.Phone = phone;
            ViewBag.Address = address;

            if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password) ||
                string.IsNullOrWhiteSpace(fullName) || string.IsNullOrWhiteSpace(email))
            {
                ViewBag.Error = "Vui lòng nhập đầy đủ thông tin bắt buộc.";
                return View();
            }

            if (password != confirmPassword)
            {
                ViewBag.Error = "Mật khẩu xác nhận không khớp.";
                return View();
            }

            if (password.Length < 6)
            {
                ViewBag.Error = "Mật khẩu phải có ít nhất 6 ký tự.";
                return View();
            }

            using (var context = CreateDbContext())
            {
                if (context.Customers.Any(c => c.Username == username))
                {
                    ViewBag.Error = "Tên đăng nhập đã tồn tại.";
                    return View();
                }

                if (context.Customers.Any(c => c.Email == email))
                {
                    ViewBag.Error = "Email đã được sử dụng.";
                    return View();
                }

                var customer = new Customer
                {
                    Username = username,
                    PasswordHash = IdentitySeed.HashPassword(password),
                    FullName = fullName,
                    Email = email,
                    Phone = phone,
                    Address = address,
                    IsActive = true
                };

                context.Customers.Add(customer);
                context.SaveChanges();

                Session["CustomerId"] = customer.Id;
                Session["CustomerName"] = customer.FullName;
                Session["CustomerUsername"] = customer.Username;
            }

            return RedirectToAction("Index", "Shop");
        }

        public ActionResult Logout()
        {
            Session.Remove("CustomerId");
            Session.Remove("CustomerName");
            Session.Remove("CustomerUsername");
            return RedirectToAction("Index", "Shop");
        }

        public ActionResult Profile()
        {
            if (Session["CustomerId"] == null)
                return RedirectToAction("Login");

            ViewBag.Title = "Thông tin tài khoản";

            using (var context = CreateDbContext())
            {
                var customerId = (int)Session["CustomerId"];
                var customer = context.Customers.FirstOrDefault(c => c.Id == customerId);
                if (customer == null)
                    return RedirectToAction("Login");

                ViewBag.Customer = customer;
            }

            return View();
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public ActionResult UpdateProfile(string fullName, string email, string phone, string address)
        {
            if (Session["CustomerId"] == null)
                return RedirectToAction("Login");

            ViewBag.Title = "Thông tin tài khoản";

            using (var context = CreateDbContext())
            {
                var customerId = (int)Session["CustomerId"];
                var customer = context.Customers.FirstOrDefault(c => c.Id == customerId);
                if (customer == null)
                    return RedirectToAction("Login");

                if (string.IsNullOrWhiteSpace(fullName) || string.IsNullOrWhiteSpace(email))
                {
                    ViewBag.Error = "Họ tên và Email không được để trống.";
                    ViewBag.Customer = customer;
                    return View("Profile");
                }

                // Check email uniqueness (exclude self)
                if (context.Customers.Any(c => c.Email == email && c.Id != customerId))
                {
                    ViewBag.Error = "Email đã được sử dụng bởi tài khoản khác.";
                    ViewBag.Customer = customer;
                    return View("Profile");
                }

                customer.FullName = fullName;
                customer.Email = email;
                customer.Phone = phone;
                customer.Address = address;
                context.SaveChanges();

                Session["CustomerName"] = customer.FullName;

                ViewBag.Success = "Cập nhật thông tin thành công!";
                ViewBag.Customer = customer;
            }

            return View("Profile");
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public ActionResult ChangePassword(string currentPassword, string newPassword, string confirmNewPassword)
        {
            if (Session["CustomerId"] == null)
                return RedirectToAction("Login");

            ViewBag.Title = "Thông tin tài khoản";

            using (var context = CreateDbContext())
            {
                var customerId = (int)Session["CustomerId"];
                var customer = context.Customers.FirstOrDefault(c => c.Id == customerId);
                if (customer == null)
                    return RedirectToAction("Login");

                ViewBag.Customer = customer;

                if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword))
                {
                    ViewBag.PasswordError = "Vui lòng nhập đầy đủ thông tin.";
                    return View("Profile");
                }

                if (IdentitySeed.HashPassword(currentPassword) != customer.PasswordHash)
                {
                    ViewBag.PasswordError = "Mật khẩu hiện tại không đúng.";
                    return View("Profile");
                }

                if (newPassword.Length < 6)
                {
                    ViewBag.PasswordError = "Mật khẩu mới phải có ít nhất 6 ký tự.";
                    return View("Profile");
                }

                if (newPassword != confirmNewPassword)
                {
                    ViewBag.PasswordError = "Mật khẩu xác nhận không khớp.";
                    return View("Profile");
                }

                customer.PasswordHash = IdentitySeed.HashPassword(newPassword);
                context.SaveChanges();

                ViewBag.PasswordSuccess = "Đổi mật khẩu thành công!";
            }

            return View("Profile");
        }

        public ActionResult MyOrders()
        {
            if (Session["CustomerId"] == null)
                return RedirectToAction("Login");

            ViewBag.Title = "Đơn hàng của tôi";
            var customerId = Session["CustomerId"].ToString();

            using (var context = CreateDbContext())
            {
                var orders = context.Orders
                    .Include(o => o.OrderDetails)
                    .Where(o => o.CreatedByUserId == customerId)
                    .OrderByDescending(o => o.CreatedAt)
                    .ToList();

                ViewBag.Orders = orders;
            }

            return View();
        }

        public ActionResult OrderDetail(int id)
        {
            if (Session["CustomerId"] == null)
                return RedirectToAction("Login");

            ViewBag.Title = "Chi tiết đơn hàng";
            var customerId = Session["CustomerId"].ToString();

            using (var context = CreateDbContext())
            {
                var order = context.Orders
                    .Include(o => o.OrderDetails)
                    .FirstOrDefault(o => o.Id == id && o.CreatedByUserId == customerId);

                if (order == null)
                    return HttpNotFound();

                ViewBag.Order = order;
            }

            return View();
        }
    }
}
