@{
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var products = ViewBag.Products as List<DesktopShop.Domain.Entities.Product>;
    var categories = ViewBag.Categories as List<DesktopShop.Domain.Entities.Category>;
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    int totalItems = ViewBag.TotalItems;
    string keyword = ViewBag.Keyword as string ?? "";
    int? categoryId = ViewBag.CategoryId as int?;
    string sort = ViewBag.Sort as string ?? "";
}

<!-- Search & Filter -->
<div class="filter-section">
    <form method="get" action="@Url.Action("Index", "Shop")" id="filterForm">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold"><i class="fas fa-search me-1"></i>Tìm kiếm</label>
                <input type="text" name="keyword" class="form-control search-box" placeholder="Nhập tên sản phẩm..." value="@keyword" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold"><i class="fas fa-sort-amount-down me-1"></i>Sắp xếp giá</label>
                <select name="sort" class="form-select" onchange="document.getElementById('filterForm').submit();">
                    <option value="">Mới nhất</option>
                    <option value="price_asc" @(sort == "price_asc" ? "selected" : "")>Giá tăng dần</option>
                    <option value="price_desc" @(sort == "price_desc" ? "selected" : "")>Giá giảm dần</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="hidden" name="categoryId" id="categoryIdInput" value="@(categoryId.HasValue ? categoryId.Value.ToString() : "")" />
                <button type="submit" class="btn btn-dark w-100"><i class="fas fa-filter me-1"></i>Lọc</button>
            </div>
            <div class="col-md-2">
                <a href="@Url.Action("Index", "Shop")" class="btn btn-outline-secondary w-100"><i class="fas fa-redo me-1"></i>Xóa lọc</a>
            </div>
        </div>
    </form>

    <!-- Category pills -->
    <div class="mt-3 d-flex flex-wrap gap-2">
        <a href="@Url.Action("Index", "Shop", new { keyword, sort })" class="category-pill @(categoryId == null ? "active" : "")">Tất cả</a>
        @if (categories != null)
        {
            foreach (var cat in categories)
            {
                <a href="@Url.Action("Index", "Shop", new { keyword, categoryId = cat.Id, sort })"
                   class="category-pill @(categoryId == cat.Id ? "active" : "")">@cat.Name</a>
            }
        }
    </div>
</div>

<!-- Results info -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">
        Tìm thấy <strong>@totalItems</strong> sản phẩm
        @if (!string.IsNullOrEmpty(keyword))
        {
            <span> cho "<em>@keyword</em>"</span>
        }
    </p>
</div>

<!-- Product Grid -->
@if (products != null && products.Any())
{
    <div class="row g-4">
        @foreach (var p in products)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="card product-card h-100 shadow-sm">
                    <a href="@Url.Action("Detail", "Shop", new { id = p.Id })">
                        @if (!string.IsNullOrEmpty(p.ImageUrl))
                        {
                            <img src="@p.ImageUrl" class="card-img-top" alt="@p.Name" />
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center bg-light">
                                <i class="fas fa-desktop fa-3x text-muted"></i>
                            </div>
                        }
                    </a>
                    <div class="card-body d-flex flex-column">
                        <span class="product-category mb-1">
                            <i class="fas fa-tag me-1"></i>@(p.Category != null ? p.Category.Name : "")
                        </span>
                        <a href="@Url.Action("Detail", "Shop", new { id = p.Id })" class="text-decoration-none">
                            <h6 class="product-name mb-2">@p.Name</h6>
                        </a>
                        <p class="text-muted small mb-2" style="font-size:0.8rem;">
                            @if (!string.IsNullOrEmpty(p.CPU))
                            {<span>@p.CPU</span>}
                            @if (!string.IsNullOrEmpty(p.RAM))
                            {<span> | @p.RAM</span>}
                        </p>
                        <div class="mt-auto">
                            <p class="product-price mb-2">@p.Price.ToString("#,0") ₫</p>
                            @if (p.StockQuantity > 0)
                            {
                                <form method="post" action="@Url.Action("Add", "Cart")">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@p.Id" />
                                    <button type="submit" class="btn btn-add-cart btn-sm w-100">
                                        <i class="fas fa-cart-plus me-1"></i>Thêm vào giỏ
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm w-100" disabled>Hết hàng</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Shop", new { keyword, categoryId, sort, page = currentPage - 1 })">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", "Shop", new { keyword, categoryId, sort, page = i })">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Shop", new { keyword, categoryId, sort, page = currentPage + 1 })">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-search fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">Không tìm thấy sản phẩm nào</h5>
        <a href="@Url.Action("Index", "Shop")" class="btn btn-outline-dark mt-2">Xem tất cả sản phẩm</a>
    </div>
}
