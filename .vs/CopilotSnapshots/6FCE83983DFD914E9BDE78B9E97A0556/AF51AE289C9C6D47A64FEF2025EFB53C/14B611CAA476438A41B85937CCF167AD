using System;
using System.Collections.Generic;
using System.Configuration;
using System.Data.SqlClient;
using System.Web.Http;
using System.Web.Http.Dependencies;
using AutoMapper;
using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.DependencyInjection;
using DesktopShop.Application.Interfaces;
using DesktopShop.Application.Mappings;
using DesktopShop.Application.Services;
using DesktopShop.Domain.Interfaces;
using DesktopShop.Infrastructure.Data;
using DesktopShop.Infrastructure.Repositories;

namespace WebApplication1
{
    public static class DependencyConfig
    {
        public static void Register(HttpConfiguration config)
        {
            var services = new ServiceCollection();

            // DbContext — use System.Data.SqlClient (built-in) instead of Microsoft.Data.SqlClient (needs native SNI.dll)
            var connectionString = ConfigurationManager.ConnectionStrings["DefaultConnection"].ConnectionString;
            EnsureDatabaseExists(connectionString);
            services.AddDbContext<ApplicationDbContext>(options =>
                options.UseSqlServer(new SqlConnection(connectionString)),
                ServiceLifetime.Scoped);

            // Repositories
            services.AddScoped<ICategoryRepository, CategoryRepository>();
            services.AddScoped<IProductRepository, ProductRepository>();
            services.AddScoped<IOrderRepository, OrderRepository>();
            services.AddScoped<IUnitOfWork, UnitOfWork>();

            // Application Services
            services.AddScoped<ICategoryService, CategoryService>();
            services.AddScoped<IProductService, ProductService>();
            services.AddScoped<IOrderService, OrderService>();
            services.AddScoped<IDashboardService, DashboardService>();

            // AutoMapper
            var mapperConfig = new MapperConfiguration(cfg =>
            {
                cfg.AddProfile<MappingProfile>();
            });
            services.AddSingleton(mapperConfig.CreateMapper());

            var provider = services.BuildServiceProvider();
            config.DependencyResolver = new ServiceProviderDependencyResolver(provider);
        }

        private static void EnsureDatabaseExists(string connectionString)
        {
            var builder = new SqlConnectionStringBuilder(connectionString);
            var dbName = builder.InitialCatalog;
            builder.InitialCatalog = "master";

            using (var connection = new SqlConnection(builder.ConnectionString))
            {
                connection.Open();
                using (var cmd = connection.CreateCommand())
                {
                    cmd.CommandText = $"IF DB_ID('{dbName}') IS NULL CREATE DATABASE [{dbName}]";
                    cmd.ExecuteNonQuery();
                }
            }
        }
    }

    public class ServiceProviderDependencyResolver : IDependencyResolver
    {
        private readonly ServiceProvider _provider;

        public ServiceProviderDependencyResolver(ServiceProvider provider)
        {
            _provider = provider;
        }

        public IDependencyScope BeginScope()
        {
            return new ServiceProviderDependencyScope(_provider.CreateScope());
        }

        public object GetService(Type serviceType)
        {
            return _provider.GetService(serviceType);
        }

        public IEnumerable<object> GetServices(Type serviceType)
        {
            return _provider.GetServices(serviceType);
        }

        public void Dispose()
        {
            _provider.Dispose();
        }
    }

    public class ServiceProviderDependencyScope : IDependencyScope
    {
        private readonly IServiceScope _scope;

        public ServiceProviderDependencyScope(IServiceScope scope)
        {
            _scope = scope;
        }

        public object GetService(Type serviceType)
        {
            return _scope.ServiceProvider.GetService(serviceType);
        }

        public IEnumerable<object> GetServices(Type serviceType)
        {
            return _scope.ServiceProvider.GetServices(serviceType);
        }

        public void Dispose()
        {
            _scope.Dispose();
        }
    }
}
