@{
    var customerName = HttpContext.Current.Session["CustomerName"] as string;
    var isLoggedIn = HttpContext.Current.Session["CustomerId"] != null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - Desktop Shop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }
        .navbar-shop {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        }
        .navbar-shop .navbar-brand {
            font-weight: 700;
            font-size: 1.4rem;
            color: #e94560 !important;
        }
        .navbar-shop .nav-link {
            color: rgba(255,255,255,.85) !important;
            font-weight: 500;
        }
        .navbar-shop .nav-link:hover {
            color: #fff !important;
        }
        .btn-cart-nav {
            position: relative;
            color: #fff !important;
        }
        .cart-badge {
            position: absolute;
            top: -4px;
            right: -8px;
            background: #e94560;
            color: #fff;
            border-radius: 50%;
            font-size: 0.65rem;
            width: 18px;
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
        }
        .product-card {
            border: none;
            border-radius: 12px;
            transition: transform 0.2s, box-shadow 0.2s;
            overflow: hidden;
        }
        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 25px rgba(0,0,0,.1);
        }
        .product-card .card-img-top {
            height: 200px;
            object-fit: cover;
            background: #e9ecef;
        }
        .product-card .card-body {
            padding: 1rem;
        }
        .product-card .product-name {
            font-weight: 600;
            font-size: 0.95rem;
            color: #333;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .product-card .product-price {
            color: #e94560;
            font-weight: 700;
            font-size: 1.1rem;
        }
        .product-card .product-category {
            font-size: 0.8rem;
            color: #888;
        }
        .btn-add-cart {
            background: #e94560;
            border: none;
            color: #fff;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        .btn-add-cart:hover {
            background: #c73652;
            color: #fff;
        }
        .footer-shop {
            background: #1a1a2e;
            color: rgba(255,255,255,.7);
            padding: 30px 0;
            margin-top: 60px;
        }
        .pagination .page-link {
            color: #1a1a2e;
        }
        .pagination .page-item.active .page-link {
            background: #e94560;
            border-color: #e94560;
        }
        .search-box {
            border-radius: 25px;
            border: 2px solid #dee2e6;
            padding: 8px 20px;
        }
        .search-box:focus {
            border-color: #e94560;
            box-shadow: 0 0 0 0.2rem rgba(233,69,96,.15);
        }
        .filter-section {
            background: #fff;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 2px 10px rgba(0,0,0,.05);
            margin-bottom: 25px;
        }
        .category-pill {
            border-radius: 20px;
            padding: 6px 16px;
            font-size: 0.85rem;
            border: 2px solid #dee2e6;
            color: #555;
            background: #fff;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
        }
        .category-pill:hover, .category-pill.active {
            background: #e94560;
            border-color: #e94560;
            color: #fff;
        }
        .toast-container {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 9999;
        }
    </style>
    @RenderSection("styles", required: false)
</head>
<body>
    <!-- Toast container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-shop sticky-top">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Shop")">
                <i class="fas fa-desktop me-2"></i>Desktop Shop
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#shopNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="shopNavbar">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Shop")"><i class="fas fa-home me-1"></i>Trang chủ</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item me-3">
                        <a class="nav-link btn-cart-nav" href="@Url.Action("Index", "Cart")">
                            <i class="fas fa-shopping-cart fa-lg"></i>
                            <span class="cart-badge" id="cartBadge">0</span>
                        </a>
                    </li>
                    @if (isLoggedIn)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user me-1"></i>@customerName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="@Url.Action("Logout", "CustomerAuth")"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login", "CustomerAuth")"><i class="fas fa-sign-in-alt me-1"></i>Đăng nhập</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Register", "CustomerAuth")"><i class="fas fa-user-plus me-1"></i>Đăng ký</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- Footer -->
    <footer class="footer-shop">
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year Desktop Shop - Cửa hàng máy tính để bàn</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(function () {
            updateCartBadge();
        });

        function updateCartBadge() {
            $.getJSON('@Url.Action("GetCartCount", "Cart")', function (data) {
                var badge = $('#cartBadge');
                badge.text(data.count);
                badge.toggle(data.count > 0);
            });
        }

        function showToast(icon, message) {
            var id = 'toast_' + Date.now();
            var bgClass = icon === 'success' ? 'bg-success' : (icon === 'error' ? 'bg-danger' : 'bg-info');
            var html = '<div id="' + id + '" class="toast align-items-center text-white ' + bgClass + ' border-0 show" role="alert">' +
                '<div class="d-flex"><div class="toast-body">' + message + '</div>' +
                '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>';
            $('#toastContainer').append(html);
            setTimeout(function () { $('#' + id).remove(); }, 3000);
        }
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>
