using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using Microsoft.EntityFrameworkCore;
using DesktopShop.Domain.Entities;
using DesktopShop.Domain.Interfaces;
using DesktopShop.Infrastructure.Data;

namespace DesktopShop.Infrastructure.Repositories;

public class CategoryRepository : Repository<Category>, ICategoryRepository
{
    public CategoryRepository(ApplicationDbContext context) : base(context) { }

    public override async Task<IEnumerable<Category>> GetAllAsync()
        => await _dbSet.Include(c => c.Products).OrderBy(c => c.Name).ToListAsync();

    public async Task<Category?> GetByNameAsync(string name)
        => await _dbSet.FirstOrDefaultAsync(c => c.Name == name);

    public async Task<IEnumerable<Category>> GetActiveCategoriesAsync()
        => await _dbSet.Include(c => c.Products).Where(c => c.IsActive).OrderBy(c => c.Name).ToListAsync();
}
