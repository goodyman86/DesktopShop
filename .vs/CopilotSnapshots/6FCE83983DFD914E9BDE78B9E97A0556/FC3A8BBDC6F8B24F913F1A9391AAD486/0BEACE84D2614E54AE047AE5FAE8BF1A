using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using DesktopShop.Application.DTOs.Dashboard;
using DesktopShop.Application.Interfaces;
using DesktopShop.Domain.Enums;
using DesktopShop.Domain.Interfaces;

namespace DesktopShop.Application.Services;

public class DashboardService : IDashboardService
{
    private readonly IUnitOfWork _unitOfWork;

    public DashboardService(IUnitOfWork unitOfWork)
    {
        _unitOfWork = unitOfWork;
    }

    public async Task<DashboardSummaryDto> GetDashboardSummaryAsync()
    {
        var allProducts = await _unitOfWork.Products.GetAllAsync();
        var allOrders = await _unitOfWork.Orders.GetAllAsync();
        var lowStock = await _unitOfWork.Products.GetLowStockProductsAsync();
        var productList = allProducts.ToList();

        var completedOrders = allOrders.Where(o => o.Status == OrderStatus.Completed).ToList();

        var summary = new DashboardSummaryDto
        {
            TotalProducts = productList.Count,
            TotalOrders = allOrders.Count(),
            TotalRevenue = completedOrders.Sum(o => o.TotalAmount),
            LowStockCount = lowStock.Count(),
            OutOfStockCount = productList.Count(p => p.StockQuantity == 0)
        };

        // Top selling: aggregate from all completed order details
        var orderDetailsGroups = new Dictionary<int, (string Name, int Qty, decimal Revenue)>();
        foreach (var order in completedOrders)
        {
            var fullOrder = await _unitOfWork.Orders.GetOrderWithDetailsAsync(order.Id);
            if (fullOrder?.OrderDetails == null) continue;
            foreach (var od in fullOrder.OrderDetails)
            {
                if (orderDetailsGroups.TryGetValue(od.ProductId, out var existing))
                {
                    orderDetailsGroups[od.ProductId] = (existing.Name, existing.Qty + od.Quantity, existing.Revenue + od.SubTotal);
                }
                else
                {
                    orderDetailsGroups[od.ProductId] = (od.ProductName, od.Quantity, od.SubTotal);
                }
            }
        }

        summary.TopSellingProducts = orderDetailsGroups
            .OrderByDescending(x => x.Value.Qty)
            .Take(5)
            .Select(x => new TopSellingProductDto
            {
                ProductName = x.Value.Name,
                TotalSold = x.Value.Qty,
                TotalRevenue = x.Value.Revenue
            }).ToList();

        return summary;
    }

    public async Task<SalesChartDto> GetSalesChartDataAsync(int months = 6)
    {
        var chart = new SalesChartDto();
        var now = DateTime.UtcNow;

        for (int i = months - 1; i >= 0; i--)
        {
            var month = now.AddMonths(-i);
            var from = new DateTime(month.Year, month.Month, 1, 0, 0, 0, DateTimeKind.Utc);
            var to = from.AddMonths(1).AddTicks(-1);

            var orders = await _unitOfWork.Orders.GetOrdersByDateRangeAsync(from, to);
            var revenue = orders
                .Where(o => o.Status == OrderStatus.Completed)
                .Sum(o => o.TotalAmount);

            chart.Labels.Add(month.ToString("MM/yyyy"));
            chart.Values.Add(revenue);
        }

        return chart;
    }

    public async Task<RevenueByDateDto> GetRevenueByDateAsync(DateTime date)
    {
        var result = new RevenueByDateDto
        {
            SelectedDate = date.ToString("dd/MM/yyyy")
        };

        // Day: from 00:00:00 to 23:59:59
        var dayStart = new DateTime(date.Year, date.Month, date.Day, 0, 0, 0, DateTimeKind.Utc);
        var dayEnd = dayStart.AddDays(1).AddTicks(-1);
        var dayOrders = await _unitOfWork.Orders.GetOrdersByDateRangeAsync(dayStart, dayEnd);
        var dayCompleted = dayOrders.Where(o => o.Status == OrderStatus.Completed).ToList();
        result.DayRevenue = dayCompleted.Sum(o => o.TotalAmount);
        result.DayOrderCount = dayCompleted.Count;

        // Month: from 1st to last day of month
        var monthStart = new DateTime(date.Year, date.Month, 1, 0, 0, 0, DateTimeKind.Utc);
        var monthEnd = monthStart.AddMonths(1).AddTicks(-1);
        var monthOrders = await _unitOfWork.Orders.GetOrdersByDateRangeAsync(monthStart, monthEnd);
        var monthCompleted = monthOrders.Where(o => o.Status == OrderStatus.Completed).ToList();
        result.MonthRevenue = monthCompleted.Sum(o => o.TotalAmount);
        result.MonthOrderCount = monthCompleted.Count;
        result.MonthLabel = "Tháng " + date.Month + "/" + date.Year;

        // Year: from Jan 1 to Dec 31
        var yearStart = new DateTime(date.Year, 1, 1, 0, 0, 0, DateTimeKind.Utc);
        var yearEnd = new DateTime(date.Year, 12, 31, 23, 59, 59, DateTimeKind.Utc);
        var yearOrders = await _unitOfWork.Orders.GetOrdersByDateRangeAsync(yearStart, yearEnd);
        var yearCompleted = yearOrders.Where(o => o.Status == OrderStatus.Completed).ToList();
        result.YearRevenue = yearCompleted.Sum(o => o.TotalAmount);
        result.YearOrderCount = yearCompleted.Count;
        result.YearLabel = "Năm " + date.Year;

        return result;
    }

    public async Task<RevenueByRangeDto> GetRevenueByRangeAsync(DateTime from, DateTime to)
    {
        var fromDate = new DateTime(from.Year, from.Month, from.Day, 0, 0, 0, DateTimeKind.Utc);
        var toDate = new DateTime(to.Year, to.Month, to.Day, 23, 59, 59, DateTimeKind.Utc);

        if (fromDate > toDate)
        {
            var temp = fromDate;
            fromDate = toDate;
            toDate = temp;
        }

        var totalDays = (int)(toDate.Date - fromDate.Date).TotalDays + 1;

        var allOrders = await _unitOfWork.Orders.GetOrdersByDateRangeAsync(fromDate, toDate);
        var completed = allOrders.Where(o => o.Status == OrderStatus.Completed).ToList();

        var result = new RevenueByRangeDto
        {
            FromDate = fromDate.ToString("dd/MM/yyyy"),
            ToDate = toDate.ToString("dd/MM/yyyy"),
            TotalDays = totalDays,
            TotalRevenue = completed.Sum(o => o.TotalAmount),
            TotalOrderCount = completed.Count
        };

        result.AverageDailyRevenue = totalDays > 0 ? result.TotalRevenue / totalDays : 0;

        // Daily breakdown
        for (var day = fromDate.Date; day <= toDate.Date; day = day.AddDays(1))
        {
            var dayEnd = day.AddDays(1).AddTicks(-1);
            var dayOrders = completed.Where(o => o.CreatedAt >= day && o.CreatedAt <= dayEnd).ToList();

            result.DailyLabels.Add(day.ToString("dd/MM"));
            result.DailyValues.Add(dayOrders.Sum(o => o.TotalAmount));
            result.DailyOrderCounts.Add(dayOrders.Count);
        }

        return result;
    }
}
