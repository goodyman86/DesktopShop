using System;
using System.Web.Http;
using System.Threading.Tasks;
using DesktopShop.Application.DTOs.Dashboard;
using DesktopShop.Application.Interfaces;

namespace DesktopShop.API.Controllers
{
    [RoutePrefix("api/dashboard")]
    public class DashboardController : ApiController
    {
        private readonly IDashboardService _dashboardService;

        public DashboardController(IDashboardService dashboardService)
        {
            _dashboardService = dashboardService;
        }

        [HttpGet]
        [Route("summary")]
        public async Task<IHttpActionResult> GetSummary()
        {
            var summary = await _dashboardService.GetDashboardSummaryAsync();
            return Ok(summary);
        }

        [HttpGet]
        [Route("sales-chart")]
        public async Task<IHttpActionResult> GetSalesChart(int months = 6)
        {
            var chart = await _dashboardService.GetSalesChartDataAsync(months);
            return Ok(chart);
        }

        [HttpGet]
        [Route("revenue-by-date")]
        public async Task<IHttpActionResult> GetRevenueByDate(string date = null)
        {
            DateTime parsedDate;
            if (string.IsNullOrEmpty(date) || !DateTime.TryParse(date, out parsedDate))
            {
                parsedDate = DateTime.UtcNow;
            }
            var result = await _dashboardService.GetRevenueByDateAsync(parsedDate);
            return Ok(result);
        }

        [HttpGet]
        [Route("revenue-by-range")]
        public async Task<IHttpActionResult> GetRevenueByRange(string from = null, string to = null)
        {
            DateTime parsedFrom;
            DateTime parsedTo;
            if (string.IsNullOrEmpty(from) || !DateTime.TryParse(from, out parsedFrom))
            {
                parsedFrom = DateTime.UtcNow.AddDays(-30);
            }
            if (string.IsNullOrEmpty(to) || !DateTime.TryParse(to, out parsedTo))
            {
                parsedTo = DateTime.UtcNow;
            }
            var result = await _dashboardService.GetRevenueByRangeAsync(parsedFrom, parsedTo);
            return Ok(result);
        }
    }
}
