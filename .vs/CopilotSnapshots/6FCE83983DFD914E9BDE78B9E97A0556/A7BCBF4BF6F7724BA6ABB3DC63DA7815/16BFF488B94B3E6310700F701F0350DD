@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h1><i class="fa-solid fa-clipboard-list me-2"></i>Quản lý Đơn Hàng</h1>
    <p>Theo dõi và quản lý tất cả đơn hàng</p>
</div>

<!-- Filter -->
<div class="filter-bar mb-3">
    <div class="search-input-wrapper">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="orderSearch" class="search-input" placeholder="Tìm theo mã đơn hoặc tên khách..." />
    </div>
    <div class="filter-buttons">
        <button class="btn-outline-modern active" data-status="-1">Tất cả</button>
        <button class="btn-outline-modern" data-status="0"><i class="fa-solid fa-clock me-1"></i>Chờ xử lý</button>
        <button class="btn-outline-modern" data-status="1"><i class="fa-solid fa-check me-1"></i>Đã xác nhận</button>
        <button class="btn-outline-modern" data-status="2"><i class="fa-solid fa-circle-check me-1"></i>Hoàn thành</button>
        <button class="btn-outline-modern" data-status="3"><i class="fa-solid fa-ban me-1"></i>Đã hủy</button>
    </div>
</div>

<!-- Orders Table -->
<div class="card-panel">
    <div class="card-panel-body p-0">
        <table class="table-modern">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>SĐT</th>
                    <th class="text-end">Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Ghi chú</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody id="ordersTableBody">
                <tr><td colspan="8" class="text-center py-4 text-muted">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Order Detail Modal -->
<div class="modal fade" id="orderDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:var(--radius);border:none;box-shadow:var(--shadow-lg);">
            <div class="modal-header" style="border-bottom:1px solid var(--gray-200);padding:16px 24px;">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-file-invoice me-2"></i>Chi tiết đơn hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <!-- Loading -->
                <div id="orderDetailLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Đang tải...</span></div>
                </div>
                <!-- Content -->
                <div id="orderDetailContent" style="display:none;">
                    <!-- Order info -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="p-3" style="background:var(--gray-50);border-radius:8px;">
                                <div class="mb-2"><span class="text-muted" style="font-size:.8rem;">Mã đơn hàng</span><br/><strong id="od_code" style="font-size:1.05rem;"></strong></div>
                                <div class="mb-2"><span class="text-muted" style="font-size:.8rem;">Ngày tạo</span><br/><span id="od_date"></span></div>
                                <div><span class="text-muted" style="font-size:.8rem;">Trạng thái</span><br/><span id="od_status"></span></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3" style="background:var(--gray-50);border-radius:8px;">
                                <div class="mb-2"><span class="text-muted" style="font-size:.8rem;">Khách hàng</span><br/><strong id="od_customer"></strong></div>
                                <div class="mb-2"><span class="text-muted" style="font-size:.8rem;">Số điện thoại</span><br/><span id="od_phone"></span></div>
                                <div><span class="text-muted" style="font-size:.8rem;">Ghi chú</span><br/><span id="od_notes" class="fst-italic"></span></div>
                            </div>
                        </div>
                    </div>
                    <!-- Order items table -->
                    <h6 class="fw-bold mb-2"><i class="fa-solid fa-box-open me-1"></i>Sản phẩm trong đơn</h6>
                    <table class="table-modern" style="margin-bottom:0;">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Tên sản phẩm</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody id="od_items"></tbody>
                        <tfoot>
                            <tr style="background:var(--gray-50);">
                                <td colspan="4" class="text-end fw-bold" style="font-size:.9rem;">Tổng cộng:</td>
                                <td class="text-end fw-bold text-danger" style="font-size:1.05rem;" id="od_total"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--gray-200);padding:12px 24px;">
                <button type="button" class="btn btn-outline-modern" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(function () {
            var API = '/api';
            var orders = [];
            var filterStatus = -1;
            var detailModal = new bootstrap.Modal(document.getElementById('orderDetailModal'));

            function loadOrders() {
                $.getJSON(API + '/orders')
                    .done(function (data) {
                        orders = Array.isArray(data) ? data : (data.data || []);
                        renderTable();
                    })
                    .fail(function () {
                        $('#ordersTableBody').html('<tr><td colspan="8" class="text-center py-4 text-danger">Không thể tải dữ liệu</td></tr>');
                    });
            }

            function renderTable() {
                var keyword = $.trim($('#orderSearch').val()).toLowerCase();
                var filtered = orders.filter(function (o) {
                    var status = o.status;
                    var matchStatus = filterStatus === -1 || status === filterStatus;
                    var code = (o.orderCode || '').toLowerCase();
                    var name = (o.customerName || '').toLowerCase();
                    var matchSearch = !keyword || code.indexOf(keyword) >= 0 || name.indexOf(keyword) >= 0;
                    return matchStatus && matchSearch;
                });

                if (!filtered.length) {
                    $('#ordersTableBody').html('<tr><td colspan="8" class="text-center py-4 text-muted">Không tìm thấy đơn hàng</td></tr>');
                    return;
                }

                var html = '';
                filtered.forEach(function (o) {
                    html += '<tr data-id="' + o.id + '">' +
                        '<td class="fw-semibold">' + (o.orderCode || '#' + o.id) + '</td>' +
                        '<td>' + o.customerName + '</td>' +
                        '<td class="text-muted">' + (o.customerPhone || '-') + '</td>' +
                        '<td class="text-end text-danger fw-bold">' + formatVND(o.totalAmount) + '</td>' +
                        '<td>' + getStatusBadge(o.status) + '</td>' +
                        '<td class="text-muted">' + formatDate(o.createdAt) + '</td>' +
                        '<td class="text-muted" style="max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="' + (o.notes || '') + '">' + (o.notes || '-') + '</td>' +
                        '<td class="text-center">' +
                            '<button class="btn btn-sm btn-outline-modern btn-view-detail" title="Chi tiết"><i class="fa-solid fa-eye"></i></button>' +
                        '</td>' +
                        '</tr>';
                });
                $('#ordersTableBody').html(html);
            }

            /* ── View order detail ── */
            $(document).on('click', '.btn-view-detail', function () {
                var id = $(this).closest('tr').data('id');
                if (!id) return;

                $('#orderDetailLoading').show();
                $('#orderDetailContent').hide();
                detailModal.show();

                $.getJSON(API + '/orders/' + id)
                    .done(function (o) {
                        $('#od_code').text(o.orderCode || '#' + o.id);
                        $('#od_date').text(formatDate(o.createdAt));
                        $('#od_status').html(getStatusBadge(o.status));
                        $('#od_customer').text(o.customerName);
                        $('#od_phone').text(o.customerPhone || '-');
                        $('#od_notes').text(o.notes || 'Không có');

                        var items = o.orderDetails || [];
                        var html = '';
                        items.forEach(function (item, idx) {
                            html += '<tr>' +
                                '<td class="text-muted">' + (idx + 1) + '</td>' +
                                '<td class="fw-semibold">' + item.productName + '</td>' +
                                '<td class="text-end">' + formatVND(item.unitPrice) + '</td>' +
                                '<td class="text-center">' + item.quantity + '</td>' +
                                '<td class="text-end text-danger fw-semibold">' + formatVND(item.subTotal) + '</td>' +
                                '</tr>';
                        });
                        if (!items.length) {
                            html = '<tr><td colspan="5" class="text-center text-muted py-3">Không có sản phẩm</td></tr>';
                        }
                        $('#od_items').html(html);
                        $('#od_total').text(formatVND(o.totalAmount));

                        $('#orderDetailLoading').hide();
                        $('#orderDetailContent').show();
                    })
                    .fail(function () {
                        $('#orderDetailLoading').hide();
                        $('#orderDetailContent').html('<div class="text-center text-danger py-4"><i class="fa-solid fa-triangle-exclamation me-1"></i>Không thể tải chi tiết đơn hàng</div>').show();
                    });
            });

            // Status filter
            $(document).on('click', '.filter-buttons .btn-outline-modern', function () {
                $('.filter-buttons .btn-outline-modern').removeClass('active');
                $(this).addClass('active');
                filterStatus = parseInt($(this).data('status'));
                renderTable();
            });

            $('#orderSearch').on('input', function () { renderTable(); });

            loadOrders();
        });
    </script>
}
