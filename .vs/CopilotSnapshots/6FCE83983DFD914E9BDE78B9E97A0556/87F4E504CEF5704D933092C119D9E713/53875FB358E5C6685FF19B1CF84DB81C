@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h1><i class="fa-solid fa-computer me-2"></i>Quản lý Sản Phẩm</h1>
        <p>Danh sách tất cả Desktop Computer trong kho hàng</p>
    </div>
    <button class="btn btn-primary-modern" id="btnAddProduct">
        <i class="fa-solid fa-plus me-1"></i>Thêm sản phẩm
    </button>
</div>

<!-- Filter -->
<div class="filter-bar mb-3">
    <div class="search-input-wrapper">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="productSearch" class="search-input" placeholder="Tìm kiếm sản phẩm..." />
    </div>
    <select id="categorySelect" class="form-select" style="width:auto;border-radius:8px;font-size:.875rem;font-family:'Inter',sans-serif;">
        <option value="0">Tất cả danh mục</option>
    </select>
</div>

<!-- Product Table -->
<div class="card-panel">
    <div class="card-panel-body p-0">
        <table class="table-modern">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th>CPU</th>
                    <th>RAM</th>
                    <th class="text-end">Giá</th>
                    <th class="text-center">Kho</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody id="productsTableBody">
                <tr><td colspan="10" class="text-center py-4 text-muted">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section scripts {
    <!-- Modal Thêm/Sửa sản phẩm -->
    <div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="productModalTitle">Thêm sản phẩm mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="productFormError" class="alert alert-danger d-none"></div>
                    <form id="productForm">
                        <input type="hidden" id="pf_Id" />
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="pf_Name" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Danh mục <span class="text-danger">*</span></label>
                                <select class="form-select" id="pf_CategoryId" required>
                                    <option value="">-- Chọn --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">CPU</label>
                                <input type="text" class="form-control" id="pf_CPU" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">RAM</label>
                                <input type="text" class="form-control" id="pf_RAM" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">GPU</label>
                                <input type="text" class="form-control" id="pf_GPU" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Storage</label>
                                <input type="text" class="form-control" id="pf_Storage" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Giá <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" id="pf_Price" min="0" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Số lượng tồn kho</label>
                                <input type="number" class="form-control" id="pf_StockQuantity" min="0" value="0" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Mức tồn kho tối thiểu</label>
                                <input type="number" class="form-control" id="pf_MinStockLevel" min="0" value="5" />
                            </div>
                            <div class="col-12">
                                <label class="form-label"><i class="fa-solid fa-globe me-1"></i>URL hình ảnh từ web</label>
                                <input type="url" class="form-control" id="pf_ExternalImageUrl"
                                       placeholder="phongvu.vn(jpg/png)" />
                                <small class="text-muted">Ảnh sẽ được tải về, resize 800px và nén 75% tự động.</small>
                            </div>
                            <div class="col-12" id="pf_ImagePreviewWrapper" style="display:none;">
                                <label class="form-label">Xem trước</label>
                                <div><img id="pf_ImagePreview" src="" style="max-width:200px;max-height:150px;border-radius:8px;border:1px solid #ddd;" /></div>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Mô tả</label>
                                <textarea class="form-control" id="pf_Description" rows="3"></textarea>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary-modern" id="btnSaveProduct">
                        <span id="btnSaveProductText">Lưu sản phẩm</span>
                        <span id="btnSaveProductLoading" class="d-none"><i class="fa-solid fa-spinner fa-spin me-1"></i>Đang xử lý...</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        $(function () {
            var API = '/api';
            var products = [];
            var categories = [];

            function loadAll() {
                $.when(
                    $.getJSON(API + '/products'),
                    $.getJSON(API + '/categories')
                ).done(function (pRes, cRes) {
                    products = Array.isArray(pRes[0]) ? pRes[0] : (pRes[0].data || []);
                    categories = Array.isArray(cRes[0]) ? cRes[0] : (cRes[0].data || []);
                    renderCategorySelect();
                    renderTable();
                }).fail(function () {
                    $('#productsTableBody').html('<tr><td colspan="10" class="text-center py-4 text-danger">Không thể tải dữ liệu</td></tr>');
                });
            }

            function renderCategorySelect() {
                var $sel = $('#categorySelect');
                var $formSel = $('#pf_CategoryId');
                categories.forEach(function (c) {
                    var id = c.Id || c.id;
                    var name = c.Name || c.name;
                    $sel.append('<option value="' + id + '">' + name + '</option>');
                    $formSel.append('<option value="' + id + '">' + name + '</option>');
                });
            }

            function renderTable() {
                var keyword = $.trim($('#productSearch').val()).toLowerCase();
                var catId = parseInt($('#categorySelect').val()) || 0;

                var filtered = products.filter(function (p) {
                    var matchCat = catId === 0 || (p.CategoryId || p.categoryId) === catId;
                    var matchSearch = !keyword || (p.Name || p.name || '').toLowerCase().indexOf(keyword) >= 0;
                    return matchCat && matchSearch;
                });

                if (!filtered.length) {
                    $('#productsTableBody').html('<tr><td colspan="10" class="text-center py-4 text-muted">Không tìm thấy sản phẩm</td></tr>');
                    return;
                }

                var html = '';
                filtered.forEach(function (p) {
                    var stock = p.StockQuantity != null ? p.StockQuantity : p.stockQuantity;
                    var minStock = p.MinStockLevel != null ? p.MinStockLevel : (p.minStockLevel || 3);
                    var stockClass = stock <= 0 ? 'text-danger fw-bold' : (stock <= minStock ? 'text-warning fw-bold' : '');
                    var imgUrl = p.ImageUrl || p.imageUrl;

                    html += '<tr>' +
                        '<td class="text-muted">#' + (p.Id || p.id) + '</td>' +
                        '<td>' + (imgUrl ? '<img src="' + imgUrl + '" style="width:40px;height:40px;border-radius:6px;object-fit:cover" />' : '<i class="fa-solid fa-image text-muted"></i>') + '</td>' +
                        '<td class="fw-semibold">' + (p.Name || p.name) + '</td>' +
                        '<td>' + (p.CategoryName || p.categoryName || '') + '</td>' +
                        '<td class="text-muted">' + (p.CPU || p.cpu || '-') + '</td>' +
                        '<td class="text-muted">' + (p.RAM || p.ram || '-') + '</td>' +
                        '<td class="text-end text-danger fw-bold">' + formatVND(p.Price || p.price) + '</td>' +
                        '<td class="text-center ' + stockClass + '">' + stock + '</td>' +
                        '<td>' + (p.IsActive !== false && p.isActive !== false ? '<span class="badge-status badge-completed">Hoạt động</span>' : '<span class="badge-status badge-cancelled">Ẩn</span>') + '</td>' +
                        '<td class="text-center">' +
                            '<button class="btn btn-sm btn-outline-modern me-1" title="Sửa"><i class="fa-solid fa-pen"></i></button>' +
                            '<button class="btn btn-sm btn-outline-modern text-danger" title="Xóa"><i class="fa-solid fa-trash"></i></button>' +
                        '</td>' +
                        '</tr>';
                });
                $('#productsTableBody').html(html);
            }

            $('#productSearch').on('input', function () { renderTable(); });
            $('#categorySelect').on('change', function () { renderTable(); });

            // --- Preview ảnh từ URL ---
            $('#pf_ExternalImageUrl').on('change blur', function () {
                var url = $.trim($(this).val());
                if (url) {
                    $('#pf_ImagePreview').attr('src', url);
                    $('#pf_ImagePreviewWrapper').show();
                } else {
                    $('#pf_ImagePreviewWrapper').hide();
                }
            });

            // --- Mở modal thêm sản phẩm ---
            $('#btnAddProduct').on('click', function () {
                $('#productModalTitle').text('Thêm sản phẩm mới');
                $('#productForm')[0].reset();
                $('#pf_Id').val('');
                $('#pf_ImagePreviewWrapper').hide();
                $('#productFormError').addClass('d-none');
                new bootstrap.Modal('#productModal').show();
            });

            // --- Lưu sản phẩm ---
            $('#btnSaveProduct').on('click', function () {
                var $btn = $(this);
                var name = $.trim($('#pf_Name').val());
                var categoryId = parseInt($('#pf_CategoryId').val()) || 0;
                var price = parseFloat($('#pf_Price').val()) || 0;

                // Validate
                if (!name || !categoryId || price <= 0) {
                    $('#productFormError').removeClass('d-none').text('Vui lòng điền đầy đủ: Tên, Danh mục, Giá > 0.');
                    return;
                }

                var data = {
                    Name: name,
                    CategoryId: categoryId,
                    CPU: $.trim($('#pf_CPU').val()) || null,
                    RAM: $.trim($('#pf_RAM').val()) || null,
                    GPU: $.trim($('#pf_GPU').val()) || null,
                    Storage: $.trim($('#pf_Storage').val()) || null,
                    Price: price,
                    StockQuantity: parseInt($('#pf_StockQuantity').val()) || 0,
                    MinStockLevel: parseInt($('#pf_MinStockLevel').val()) || 5,
                    ExternalImageUrl: $.trim($('#pf_ExternalImageUrl').val()) || null,
                    Description: $.trim($('#pf_Description').val()) || null
                };

                // Show loading
                $('#btnSaveProductText').addClass('d-none');
                $('#btnSaveProductLoading').removeClass('d-none');
                $btn.prop('disabled', true);
                $('#productFormError').addClass('d-none');

                $.ajax({
                    url: API + '/products',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    success: function (result) {
                        bootstrap.Modal.getInstance(document.getElementById('productModal')).hide();
                        loadAll();
                    },
                    error: function (xhr) {
                        var msg = 'Lỗi không xác định.';
                        try {
                            var resp = JSON.parse(xhr.responseText);
                            msg = resp.Message || resp.message || resp.ExceptionMessage || resp.exceptionMessage || msg;
                        } catch (e) {
                            if (xhr.responseText) msg = xhr.responseText;
                        }
                        $('#productFormError').removeClass('d-none').text(msg);
                    },
                    complete: function () {
                        $('#btnSaveProductText').removeClass('d-none');
                        $('#btnSaveProductLoading').addClass('d-none');
                        $btn.prop('disabled', false);
                    }
                });
            });

            loadAll();
        });
    </script>
}
