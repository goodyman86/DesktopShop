@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h1><i class="fa-solid fa-clipboard-list me-2"></i>Quản lý Đơn Hàng</h1>
    <p>Theo dõi và quản lý tất cả đơn hàng</p>
</div>

<!-- Filter -->
<div class="filter-bar mb-3">
    <div class="search-input-wrapper">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="orderSearch" class="search-input" placeholder="Tìm theo mã đơn hoặc tên khách..." />
    </div>
    <div class="filter-buttons">
        <button class="btn-outline-modern active" data-status="-1">Tất cả</button>
        <button class="btn-outline-modern" data-status="0"><i class="fa-solid fa-clock me-1"></i>Chờ xử lý</button>
        <button class="btn-outline-modern" data-status="1"><i class="fa-solid fa-check me-1"></i>Đã xác nhận</button>
        <button class="btn-outline-modern" data-status="2"><i class="fa-solid fa-circle-check me-1"></i>Hoàn thành</button>
        <button class="btn-outline-modern" data-status="3"><i class="fa-solid fa-ban me-1"></i>Đã hủy</button>
    </div>
</div>

<!-- Orders Table -->
<div class="card-panel">
    <div class="card-panel-body p-0">
        <table class="table-modern">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>SĐT</th>
                    <th class="text-end">Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Ghi chú</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody id="ordersTableBody">
                <tr><td colspan="8" class="text-center py-4 text-muted">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section scripts {
    <script>
        $(function () {
            var API = '/api';
            var orders = [];
            var filterStatus = -1;

            function loadOrders() {
                $.getJSON(API + '/orders')
                    .done(function (data) {
                        orders = Array.isArray(data) ? data : (data.data || data.Data || []);
                        renderTable();
                    })
                    .fail(function () {
                        $('#ordersTableBody').html('<tr><td colspan="8" class="text-center py-4 text-danger">Không thể tải dữ liệu</td></tr>');
                    });
            }

            function renderTable() {
                var keyword = $.trim($('#orderSearch').val()).toLowerCase();
                var filtered = orders.filter(function (o) {
                    var status = o.Status != null ? o.Status : o.status;
                    var matchStatus = filterStatus === -1 || status === filterStatus;
                    var code = (o.OrderCode || o.orderCode || '').toLowerCase();
                    var name = (o.CustomerName || o.customerName || '').toLowerCase();
                    var matchSearch = !keyword || code.indexOf(keyword) >= 0 || name.indexOf(keyword) >= 0;
                    return matchStatus && matchSearch;
                });

                if (!filtered.length) {
                    $('#ordersTableBody').html('<tr><td colspan="8" class="text-center py-4 text-muted">Không tìm thấy đơn hàng</td></tr>');
                    return;
                }

                var html = '';
                filtered.forEach(function (o) {
                    html += '<tr>' +
                        '<td class="fw-semibold">' + (o.OrderCode || o.orderCode || '#' + (o.Id || o.id)) + '</td>' +
                        '<td>' + (o.CustomerName || o.customerName) + '</td>' +
                        '<td class="text-muted">' + (o.CustomerPhone || o.customerPhone || '-') + '</td>' +
                        '<td class="text-end text-danger fw-bold">' + formatVND(o.TotalAmount || o.totalAmount) + '</td>' +
                        '<td>' + getStatusBadge(o.Status != null ? o.Status : o.status) + '</td>' +
                        '<td class="text-muted">' + formatDate(o.CreatedAt || o.createdAt) + '</td>' +
                        '<td class="text-muted" style="max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="' + (o.Notes || o.notes || '') + '">' + (o.Notes || o.notes || '-') + '</td>' +
                        '<td class="text-center">' +
                            '<button class="btn btn-sm btn-outline-modern" title="Chi tiết"><i class="fa-solid fa-eye"></i></button>' +
                        '</td>' +
                        '</tr>';
                });
                $('#ordersTableBody').html(html);
            }

            // Status filter
            $(document).on('click', '.filter-buttons .btn-outline-modern', function () {
                $('.filter-buttons .btn-outline-modern').removeClass('active');
                $(this).addClass('active');
                filterStatus = parseInt($(this).data('status'));
                renderTable();
            });

            $('#orderSearch').on('input', function () { renderTable(); });

            loadOrders();
        });
    </script>
}
